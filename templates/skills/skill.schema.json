{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/skill-template.schema.json",
  "title": "ATM Skill Template",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "id",
    "title",
    "summary",
    "command",
    "firstCommand",
    "charter-invariants-injected",
    "handoffs"
  ],
  "properties": {
    "schemaId": { "const": "atm.skillTemplate" },
    "specVersion": { "const": "0.1.0" },
    "id": { "type": "string", "pattern": "^(atm|mailbox)-[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "pattern": "^node atm\\.mjs " },
    "firstCommand": {
      "enum": [
        "node atm.mjs next --json",
        "node atm.mjs next --prompt \"$ARGUMENTS\" --json",
        "node atm.mjs next --intent .atm/runtime/task-intent.json --json"
      ]
    },
    "charter-invariants-injected": { "const": true },
    "handoffs": { "type": "string", "pattern": "^node atm\\.mjs " },
    "skillDefinition": {
      "$ref": "#/$defs/skillDefinitionVNext"
    }
  },
  "$defs": {
    "skillDefinitionVNext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaId",
        "specVersion",
        "provider",
        "capabilities",
        "compatibility",
        "fallbackPolicy",
        "rollbackPolicy"
      ],
      "properties": {
        "schemaId": { "const": "atm.skillDefinition.vNext" },
        "specVersion": { "const": "0.1.0" },
        "provider": { "$ref": "#/$defs/providerProvenance" },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["atmContractVersions"],
          "properties": {
            "atmContractVersions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true }
          }
        },
        "fallbackPolicy": { "enum": ["deny", "degrade-with-evidence", "legacy-compatible"] },
        "rollbackPolicy": { "enum": ["provider-only", "manifest-only", "full-revert"] },
        "shadowRun": { "type": "boolean" },
        "promotion": { "enum": ["manual-review", "measured-promotion", "disabled"] }
      }
    },
    "providerProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "version", "provenance", "license"],
      "properties": {
        "providerId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["upstreamUrl", "upstreamCommit", "sourceDigest"],
          "properties": {
            "upstreamUrl": { "type": "string", "format": "uri" },
            "upstreamCommit": { "type": "string", "minLength": 1 },
            "sourceDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        },
        "license": { "type": "string", "minLength": 1 }
      }
    }
  }
}
