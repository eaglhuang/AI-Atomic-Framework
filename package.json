{
  "name": "ai-atomic-framework",
  "version": "0.0.0",
  "private": true,
  "description": "Governance framework for AI-assisted atomic engineering work.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "packages:list": "node scripts/list-packages.mjs",
    "sync:registry-artifacts": "node scripts/sync-registry-artifacts.mjs",
    "build": "tsc -p tsconfig.build.json && node scripts/build-package-dist.mjs && node scripts/build-root-drop-release.mjs && node scripts/build-onefile-release.mjs",
    "build:root-drop-release": "node scripts/build-root-drop-release.mjs",
    "build:onefile-release": "node scripts/build-onefile-release.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "node scripts/run-validators.mjs test",
    "validate:quick": "node scripts/run-validators.mjs quick",
    "validate:standard": "node scripts/run-validators.mjs standard",
    "validate:full": "node scripts/run-validators.mjs full",
    "validate:schemas": "node scripts/validate-schemas.mjs --mode validate",
    "validate:cli": "node scripts/validate-cli.mjs --mode validate",
    "validate:guide": "node scripts/validate-guide.mjs --mode validate",
    "validate:git-head-evidence": "node scripts/validate-git-head-evidence.mjs --mode validate",
    "validate:adapter-local-git": "node scripts/validate-local-git-adapter.mjs --mode validate",
    "validate:language-js": "node scripts/validate-language-js.mjs --mode validate",
    "validate:examples": "node scripts/validate-examples.mjs --mode validate",
    "validate:bootstrap": "node scripts/validate-bootstrap.mjs --mode validate",
    "validate:root-drop-release": "node scripts/validate-root-drop-release.mjs --mode validate",
    "validate:onefile-release": "node scripts/validate-onefile-release.mjs --mode validate",
    "validate:self-hosting-alpha": "node scripts/validate-self-hosting-alpha.mjs --mode validate",
    "validate:test-facade": "node scripts/validate-test-facade.mjs --mode validate",
    "validate:seed-spec": "node scripts/validate-seed-spec.mjs --mode validate",
    "validate:seed-registry": "node scripts/validate-seed-registry.mjs --mode validate",
    "validate:registry-catalog": "node scripts/validate-registry-catalog.mjs --mode validate",
    "validate:core-spec-parser": "node scripts/validate-core-spec-parser.mjs --mode validate",
    "validate:scaffold-builder": "node scripts/validate-scaffold-builder.mjs --mode validate",
    "validate:agent-prompt": "node scripts/validate-agent-prompt.mjs --mode validate",
    "validate:agent-execute": "node scripts/validate-agent-execute.mjs --mode validate",
    "validate:upgrade-proposal": "node scripts/validate-upgrade-proposal.mjs --mode validate",
    "validate:rollback-proof": "node scripts/validate-rollback-proof.mjs --mode validate",
    "validate:human-review": "node scripts/validate-human-review.mjs --mode validate",
    "validate:review-advisory": "node scripts/validate-review-advisory.mjs --mode validate",
    "validate:governance-commands": "node scripts/validate-governance-commands.mjs --mode validate",
    "validate:external-golden": "node scripts/validate-external-golden.mjs --mode validate",
    "validate:polymorph-template": "node scripts/validate-polymorph-template.mjs --mode validate",
    "validate:test-runner": "node scripts/validate-test-runner.mjs --mode validate",
    "validate:registry-core": "node scripts/validate-registry-core.mjs --mode validate",
    "validate:status-machine": "node scripts/validate-status-machine.mjs --mode validate",
    "validate:behavior-sdk": "node scripts/validate-behavior-sdk.mjs --mode validate",
    "validate:behavior-pack": "node scripts/validate-behavior-pack.mjs --mode validate",
    "validate:registry-index": "node scripts/validate-registry-index.mjs --mode validate",
    "validate:semantic-fingerprint": "node scripts/validate-semantic-fingerprint.mjs --mode validate",
    "validate:generator-provenance": "node scripts/validate-generator-provenance.mjs --mode validate",
    "validate:map-template": "node scripts/validate-map-template.mjs --mode validate",
    "validate:map-generator-provenance": "node scripts/validate-map-generator-provenance.mjs --mode validate",
    "validate:police": "node scripts/validate-police.mjs --mode validate",
    "validate:plugin-sdk": "node scripts/validate-plugin-sdk.mjs --mode validate",
    "validate:governance-local": "node scripts/validate-governance-local.mjs --mode validate",
    "validate:neutrality": "node scripts/validate-neutrality-scanner.mjs --mode validate",
    "validate:multi-agent-confidence": "node scripts/validate-multi-agent-confidence.mjs --mode validate",
    "validate:registry-diff": "node scripts/validate-registry-diff.mjs --mode validate",
    "validate:regression-compare": "node scripts/validate-regression-compare.mjs --mode validate",
    "validate:hash-placeholders": "node scripts/audit-hash-placeholders.mjs --mode validate",
    "generate:multi-agent-confidence": "node scripts/generate-multi-agent-confidence-reports.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
