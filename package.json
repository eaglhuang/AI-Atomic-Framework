    "validate:polymorph-template": "node --experimental-strip-types scripts/validate-polymorph-template.ts --mode validate",
    "validate:test-runner": "node --experimental-strip-types scripts/validate-test-runner.ts --mode validate",
    "validate:registry-core": "node --experimental-strip-types scripts/validate-registry-core.ts --mode validate",
    "validate:status-machine": "node --experimental-strip-types scripts/validate-status-machine.ts --mode validate",
    "validate:behavior-sdk": "node --experimental-strip-types scripts/validate-behavior-sdk.ts --mode validate",
    "validate:behavior-pack": "node --experimental-strip-types scripts/validate-behavior-pack.ts --mode validate",
    "validate:registry-index": "node --experimental-strip-types scripts/validate-registry-index.ts --mode validate",
    "validate:semantic-fingerprint": "node --experimental-strip-types scripts/validate-semantic-fingerprint.ts --mode validate",
    "validate:generator-provenance": "node --experimental-strip-types scripts/validate-generator-provenance.ts --mode validate",
    "validate:map-template": "node --experimental-strip-types scripts/validate-map-template.ts --mode validate",
    "validate:map-generator-provenance": "node --experimental-strip-types scripts/validate-map-generator-provenance.ts --mode validate",
    "validate:police": "node --experimental-strip-types scripts/validate-police.ts --mode validate",
    "validate:plugin-sdk": "node --experimental-strip-types scripts/validate-plugin-sdk.ts --mode validate",
    "validate:governance-local": "node --experimental-strip-types scripts/validate-governance-local.ts --mode validate",
    "validate:neutrality": "node --experimental-strip-types scripts/validate-neutrality-scanner.ts --mode validate",
    "validate:multi-agent-confidence": "node --experimental-strip-types scripts/validate-multi-agent-confidence.ts --mode validate",
    "validate:registry-diff": "node --experimental-strip-types scripts/validate-registry-diff.ts --mode validate",
    "validate:regression-compare": "node --experimental-strip-types scripts/validate-regression-compare.ts --mode validate",
    "validate:hash-placeholders": "node --experimental-strip-types scripts/audit-hash-placeholders.ts --mode validate",
    "validate:rollout-metrics": "node --experimental-strip-types scripts/validate-rollout-metrics.ts --mode validate",
    "generate:multi-agent-confidence": "node --experimental-strip-types scripts/generate-multi-agent-confidence-reports.ts",
    "generate:error-codes": "node --experimental-strip-types scripts/generate-error-code-index.ts",
    "sync:registry-versions": "node --experimental-strip-types scripts/backfill-registry-versions.ts",
    "health:post-merge": "node --experimental-strip-types scripts/check-main-health.ts"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
