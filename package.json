{
  "name": "ai-atomic-framework",
  "version": "0.0.0",
  "private": true,
  "description": "Governance framework for AI-assisted atomic engineering work.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "packages:list": "node --experimental-strip-types scripts/list-packages.ts",
    "sync:registry-artifacts": "node --experimental-strip-types scripts/sync-registry-artifacts.ts",
    "build": "tsc -p tsconfig.build.json && node --experimental-strip-types scripts/build-package-dist.ts && node --experimental-strip-types scripts/build-root-drop-release.ts && node --experimental-strip-types scripts/build-onefile-release.ts",
    "build:root-drop-release": "node --experimental-strip-types scripts/build-root-drop-release.ts",
    "build:onefile-release": "node --experimental-strip-types scripts/build-onefile-release.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "node --experimental-strip-types scripts/run-validators.ts test",
    "validate:quick": "node --experimental-strip-types scripts/run-validators.ts quick",
    "validate:standard": "node --experimental-strip-types scripts/run-validators.ts standard",
    "validate:full": "node --experimental-strip-types scripts/run-validators.ts full --parallel",
    "validate:schemas": "node --experimental-strip-types scripts/validate-schemas.ts --mode validate",
    "validate:cli": "node --experimental-strip-types scripts/validate-cli.ts --mode validate",
    "validate:guidance": "node --experimental-strip-types scripts/validate-guidance.ts --mode validate",
    "validate:guide": "node --experimental-strip-types scripts/validate-guide.ts --mode validate",
    "validate:evidence-detector": "node --experimental-strip-types scripts/validate-evidence-detector.ts --mode validate",
    "validate:map-curator": "node --experimental-strip-types scripts/validate-map-curator.ts --mode validate",
    "validate:git-head-evidence": "node --experimental-strip-types scripts/validate-git-head-evidence.ts --mode validate",
    "validate:git-hooks-enforcement": "node --experimental-strip-types scripts/validate-git-hooks-enforcement.ts --mode validate",
    "validate:adapter-local-git": "node --experimental-strip-types scripts/validate-local-git-adapter.ts --mode validate",
    "validate:language-js": "node --experimental-strip-types scripts/validate-language-js.ts --mode validate",
    "validate:examples": "node --experimental-strip-types scripts/validate-examples.ts --mode validate",
    "validate:bootstrap": "node --experimental-strip-types scripts/validate-bootstrap.ts --mode validate",
    "validate:root-drop-release": "node --experimental-strip-types scripts/validate-root-drop-release.ts --mode validate",
    "validate:onefile-release": "node --experimental-strip-types scripts/validate-onefile-release.ts --mode validate",
    "validate:self-hosting-alpha": "node --experimental-strip-types scripts/validate-self-hosting-alpha.ts --mode validate",
    "validate:test-facade": "node --experimental-strip-types scripts/validate-test-facade.ts --mode validate",
    "validate:module-boundaries": "node --experimental-strip-types scripts/validate-module-boundaries.ts --mode validate",
    "validate:type-schema-sync": "node --experimental-strip-types scripts/validate-type-schema-sync.ts --mode validate",
    "validate:seed-spec": "node --experimental-strip-types scripts/validate-seed-spec.ts --mode validate",
    "validate:seed-registry": "node --experimental-strip-types scripts/validate-seed-registry.ts --mode validate",
    "validate:registry-catalog": "node --experimental-strip-types scripts/validate-registry-catalog.ts --mode validate",
    "validate:core-spec-parser": "node --experimental-strip-types scripts/validate-core-spec-parser.ts --mode validate",
    "validate:scaffold-builder": "node --experimental-strip-types scripts/validate-scaffold-builder.ts --mode validate",
    "validate:agent-prompt": "node --experimental-strip-types scripts/validate-agent-prompt.ts --mode validate",
    "validate:agent-execute": "node --experimental-strip-types scripts/validate-agent-execute.ts --mode validate",
    "validate:upgrade-proposal": "node --experimental-strip-types scripts/validate-upgrade-proposal.ts --mode validate",
    "validate:rollback-proof": "node --experimental-strip-types scripts/validate-rollback-proof.ts --mode validate",
    "validate:human-review": "node --experimental-strip-types scripts/validate-human-review.ts --mode validate",
    "validate:review-advisory": "node --experimental-strip-types scripts/validate-review-advisory.ts --mode validate",
