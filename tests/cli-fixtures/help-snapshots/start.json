{
  "command": "start",
  "summary": "Start an ATM guidance session for a concrete goal.",
  "positional": [],
  "options": [
    {
      "flag": "--cwd",
      "value": "path",
      "summary": "Run the command against a specific repository root."
    },
    {
      "flag": "--goal",
      "value": "text",
      "summary": "Goal the agent is trying to accomplish."
    },
    {
      "flag": "--actor",
      "value": "name",
      "summary": "Optional actor label for session audit."
    },
    {
      "flag": "--json",
      "summary": "Force machine-readable JSON output."
    },
    {
      "flag": "--pretty",
      "summary": "Force human-readable pretty output."
    },
    {
      "flag": "--help",
      "alias": "-h",
      "summary": "Show command help."
    }
  ],
  "examples": [
    "node atm.mjs start --cwd . --goal \"Extract legacy helper\" --json"
  ]
}
