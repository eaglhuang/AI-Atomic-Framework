{
  "command": "next",
  "summary": "Recommend the next official ATM guidance action from current state.",
  "positional": [],
  "options": [
    {
      "flag": "--cwd",
      "value": "path",
      "summary": "Run the command against a specific repository root."
    },
    {
      "flag": "--claim",
      "summary": "Claim the selected imported task as part of next-action routing."
    },
    {
      "flag": "--actor",
      "value": "id",
      "summary": "Actor id used for next --claim (or set ATM_ACTOR_ID)."
    },
    {
      "flag": "--json",
      "summary": "Force machine-readable JSON output."
    },
    {
      "flag": "--pretty",
      "summary": "Force human-readable pretty output."
    },
    {
      "flag": "--help",
      "alias": "-h",
      "summary": "Show command help."
    }
  ],
  "examples": [
    "node atm.mjs next --json",
    "node atm.mjs next --cwd <host-repo> --json",
    "node atm.mjs next --claim --actor codex-main --json"
  ]
}
