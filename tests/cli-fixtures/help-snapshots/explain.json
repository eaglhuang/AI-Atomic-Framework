{
  "command": "explain",
  "summary": "Explain guidance blocks and the evidence needed to proceed.",
  "positional": [],
  "options": [
    {
      "flag": "--cwd",
      "value": "path",
      "summary": "Run the command against a specific repository root."
    },
    {
      "flag": "--why",
      "value": "reason",
      "summary": "Currently supports: blocked."
    },
    {
      "flag": "--session",
      "value": "id",
      "summary": "Guidance session id; defaults to the active session."
    },
    {
      "flag": "--json",
      "summary": "Force machine-readable JSON output."
    },
    {
      "flag": "--pretty",
      "summary": "Force human-readable pretty output."
    },
    {
      "flag": "--help",
      "alias": "-h",
      "summary": "Show command help."
    }
  ],
  "examples": [
    "node atm.mjs explain --why blocked --json",
    "node atm.mjs explain --why blocked --session <session-id> --json"
  ]
}
