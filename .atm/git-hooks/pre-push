#!/usr/bin/env sh
set -eu
# ATM_INTEGRATION_HOOK_CONTRACT_V1

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

runner="atm.mjs"
if [ -f "atm.dev.mjs" ] && [ -f "packages/cli/src/atm.ts" ] && [ -f "packages/core/src/index.ts" ]; then
  runner="atm.dev.mjs"
fi

node "$runner" hook pre-push --json
