    "scripts/validate-task-ledger-governance.ts",
    "docs/specs/taskflow-profile-v1.md"
  ],
  "validators": [
    "npm run typecheck",
    "npm run validate:cli",
    "node --strip-types scripts/validate-task-ledger-governance.ts --mode validate",
    "git diff --check"
  ],
  "planningRepo": "3KLife",
