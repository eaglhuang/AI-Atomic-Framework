{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/police/lifecycle-notice.schema.json",
  "title": "ATM Lifecycle Police Notice v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "noticeId",
    "atomId",
    "callerIds",
    "recommendedAction",
    "reason"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.police.lifecycleNotice"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "noticeId": {
      "type": "string",
      "minLength": 1
    },
    "atomId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "callerIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendedAction": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
