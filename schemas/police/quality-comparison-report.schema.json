{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/police/quality-comparison-report.schema.json",
  "title": "ATM Police Quality Comparison Report v0.1",
  "description": "Compares quality metrics between two atom versions, enforcing non-regression and tracking map-level impact.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "reportId", "generatedAt", "lifecycleMode", "atomId", "fromVersion", "toVersion", "metrics", "regressed", "passed"],
  "properties": {
    "schemaId": {
      "const": "atm.police.qualityComparisonReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "pattern": "^police\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycleMode": {
      "enum": ["birth", "evolution"]
    },
    "atomId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "fromVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "toVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metricDelta"
      }
    },
    "regressed": {
      "type": "boolean",
      "description": "True if any metric has degraded beyond tolerance."
    },
    "passed": {
      "type": "boolean",
      "description": "False if regressed or any map integration test failed."
    },
    "regressedMetrics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Names of metrics that regressed."
    },
    "mapImpactScope": {
      "$ref": "#/$defs/mapImpactScope"
    },
    "dedupCandidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dedupCandidate"
      },
      "description": "Advisory: atoms with similar or identical semantic fingerprint."
    },
    "dedupIgnoredAsPolymorph": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dedupIgnoredCandidate"
      },
      "description": "Candidates ignored because they are polymorphic instances in the same template group."
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "metricDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseline", "current", "delta", "direction", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "type": "number"
        },
        "current": {
          "type": "number"
        },
        "delta": {
          "type": "number"
        },
        "direction": {
          "enum": ["higher-is-better", "lower-is-better", "informational"]
        },
        "tolerance": {
          "type": "number",
          "minimum": 0,
          "description": "Allowed degradation threshold (absolute). Only for lower-is-better or higher-is-better."
        },
        "passed": {
          "type": "boolean"
        }
      }
    },
    "mapImpactScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["affectedMapIds", "propagationStatus"],
      "properties": {
        "affectedMapIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ATM-MAP-\\d{4}$"
          }
        },
        "propagationStatus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mapPropagation"
          }
        }
      }
    },
    "mapPropagation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapId", "integrationTestPassed"],
      "properties": {
        "mapId": {
          "type": "string",
          "pattern": "^ATM-MAP-\\d{4}$"
        },
        "integrationTestPassed": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "dedupCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "similarity"],
      "properties": {
        "atomId": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "similarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "semanticFingerprint": {
          "type": "string"
        },
        "polymorphGroupId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        }
      }
    },
    "dedupIgnoredCandidate": {
      "allOf": [
        {
          "$ref": "#/$defs/dedupCandidate"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["atomId", "similarity", "ignoredAsPolymorph", "reason"],
          "properties": {
            "ignoredAsPolymorph": {
              "const": true
            },
            "reason": {
              "enum": ["instance-atom", "same-polymorph-group"]
            }
          }
        }
      ]
    }
  }
}
