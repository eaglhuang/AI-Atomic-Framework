{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/police/quality-comparison-report.schema.json",
  "title": "ATM Police Quality Comparison Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "reportId", "generatedAt", "lifecycleMode", "metrics", "regressed", "passed"],
  "properties": {
    "schemaId": {
      "const": "atm.police.qualityComparisonReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "pattern": "^police\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycleMode": {
      "enum": ["birth", "evolution"]
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metricDelta"
      }
    },
    "regressed": {
      "type": "boolean"
    },
    "passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "metricDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseline", "current", "delta", "direction", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "type": "number"
        },
        "current": {
          "type": "number"
        },
        "delta": {
          "type": "number"
        },
        "direction": {
          "enum": ["higher-is-better", "lower-is-better", "informational"]
        },
        "passed": {
          "type": "boolean"
        }
      }
    }
  }
}
