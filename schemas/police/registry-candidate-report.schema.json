{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/police/registry-candidate-report.schema.json",
  "title": "ATM Police Registry Candidate Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "reportId", "generatedAt", "lifecycleMode", "candidateId", "candidateStatus", "checks", "passed", "canPromote"],
  "properties": {
    "schemaId": {
      "const": "atm.police.registryCandidateReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "pattern": "^police\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycleMode": {
      "enum": ["birth", "evolution"]
    },
    "candidateId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "candidateStatus": {
      "enum": ["seed", "active", "experimental", "deprecated", "governed"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checkResult"
      }
    },
    "passed": {
      "type": "boolean"
    },
    "canPromote": {
      "type": "boolean"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
