{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atm.teamWaveEnvelope.v1",
  "title": "ATM Team Wave Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "waveId",
    "coordinatorActorId",
    "targetRepo",
    "closureAuthority",
    "members",
    "metadata"
  ],
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": { "enum": ["none", "additive", "breaking"] },
        "fromVersion": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "notes": { "type": "string" }
      }
    }
  },
  "properties": {
    "schemaId": { "const": "atm.teamWaveEnvelope.v1" },
    "specVersion": { "const": "0.1.0" },
    "migration": { "$ref": "#/$defs/migration" },
    "waveId": { "type": "string", "minLength": 1 },
    "coordinatorActorId": { "type": "string", "minLength": 1 },
    "targetRepo": { "type": ["string", "null"] },
    "closureAuthority": { "type": ["string", "null"] },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "workerActorId", "scopePaths", "deliverables", "patchEnvelopeId"],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "workerActorId": { "type": ["string", "null"] },
          "scopePaths": { "type": "array", "items": { "type": "string" } },
          "deliverables": { "type": "array", "items": { "type": "string" } },
          "patchEnvelopeId": { "type": ["string", "null"] },
          "executionState": {
            "type": "string",
            "enum": ["done", "partial", "blocked", "not-started", "needs-review"]
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plannedAt", "waveIndex"],
      "properties": {
        "plannedAt": { "type": "string" },
        "waveIndex": { "type": "integer", "minimum": 0 },
        "appendSafePaths": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
