{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/registry/atomic-map.schema.json",
  "title": "ATM Atomic Map v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "mapId", "mapVersion", "members", "edges", "entrypoints", "qualityTargets", "mapHash"],
  "properties": {
    "schemaId": {
      "const": "atm.atomicMap"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "mapId": {
      "type": "string",
      "pattern": "^map\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "mapVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/member"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
      }
    },
    "qualityTargets": {
      "$ref": "#/$defs/qualityTargets"
    },
    "mapHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "semanticFingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "lineageLogRef": {
      "type": "string",
      "minLength": 1
    },
    "ttl": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "version"],
      "properties": {
        "atomId": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "binding"],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "to": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "binding": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "qualityTargets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      }
    }
  }
}