{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/registry/fingerprint-profile.schema.json",
  "title": "ATM CID Fingerprint Profile v0.1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          },
          "default": []
        },
        "language": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary": {
              "enum": ["language-neutral", "javascript", "typescript", "json", "markdown", "shell", "other"]
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "evidenceRequired": {
              "type": "boolean"
            }
          }
        },
        "performanceBudget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hotPath": {
              "type": "boolean"
            },
            "inputMutation": {
              "enum": ["forbidden", "allowed", "clone-on-write"]
            },
            "maxDurationMs": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "strict": {
      "type": "object",
      "additionalProperties": false
    },
    "effects": {
      "type": "object",
      "additionalProperties": false
    },
    "semantic": {
      "type": "object",
      "additionalProperties": false
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false
    }
  },
  "$defs": {
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "kind": {
          "enum": ["json", "text", "file", "directory", "artifact", "evidence"]
        },
        "required": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
