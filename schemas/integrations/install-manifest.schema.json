{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/integrations/install-manifest.schema.json",
  "title": "ATM Integration Install Manifest v0.1",
  "description": "Hash-locked manifest for files installed by an ATM IntegrationAdapter.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "adapterId", "adapterVersion", "installedAt", "targetDir", "files"],
  "properties": {
    "schemaId": {
      "const": "atm.integrationInstallManifest"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "adapterId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "adapterVersion": {
      "type": "string",
      "minLength": 1
    },
    "installedAt": {
      "type": "string",
      "format": "date-time"
    },
    "installedBy": {
      "type": "string",
      "minLength": 1
    },
    "targetDir": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))(?!.*:).+"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manifestFile"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "manifestFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "sizeBytes", "source", "fileFormat"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))(?!.*:).+"
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "enum": ["template", "generated", "copied"]
        },
        "fileFormat": {
          "enum": ["skill", "agent-md", "prompt-md", "instructions-md", "toml", "yaml", "markdown"]
        }
      }
    }
  }
}
