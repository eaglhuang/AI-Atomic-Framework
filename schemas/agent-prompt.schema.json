{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/agent-prompt.schema.json",
  "title": "ATM Agent Prompt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "atomId",
    "title",
    "lifecycleMode",
    "promptPath",
    "frontmatter",
    "sections",
    "markdown"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.agentPrompt"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "atomId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "lifecycleMode": {
      "enum": ["birth", "evolution"]
    },
    "promptPath": {
      "type": "string",
      "minLength": 1
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbiddenRules", "allowedFiles", "evidenceContract"],
      "properties": {
        "forbiddenRules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowedFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidenceContract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["evidenceRequired", "requiredOutputs", "validationCommands"],
          "properties": {
            "evidenceRequired": {
              "type": "boolean"
            },
            "requiredOutputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "validationCommands": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "context", "inputs", "outputs", "instructions"],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "instructions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "required"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    }
  }
}