{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/registry.schema.json",
  "title": "ATM Registry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "registryId", "generatedAt", "entries"],
  "properties": {
    "schemaId": {
      "const": "atm.registry"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "registryId": {
      "type": "string",
      "pattern": "^registry\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sharding": {
      "$ref": "#/$defs/sharding"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/registryEntry"
          },
          {
            "$ref": "#/$defs/mapRegistryEntry"
          }
        ]
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "registryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atomId",
        "schemaId",
        "specVersion",
        "schemaPath",
        "specPath",
        "hashLock",
        "owner",
        "status",
        "governance",
        "compatibility",
        "evidence",
        "selfVerification"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "atomId": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "logicalName": {
          "type": "string",
          "pattern": "^atom\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "atomVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "currentVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/registryVersion"
          }
        },
        "semanticFingerprint": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(?:sf:)?sha256:[a-f0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "lineageLogRef": {
          "type": "string",
          "minLength": 1
        },
        "evidenceIndexRef": {
          "type": "string",
          "minLength": 1
        },
        "ttl": {
          "type": "integer",
          "minimum": 0
        },
        "schemaId": {
          "const": "atm.atomicSpec"
        },
        "specVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaPath": {
          "type": "string",
          "pattern": "^schemas/.+\\.schema\\.json$"
        },
        "specPath": {
          "type": "string",
          "minLength": 1
        },
        "hashLock": {
          "$ref": "#/$defs/hashLock"
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "contact"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "contact": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "status": {
          "enum": ["draft", "validated", "active", "transitioning", "deprecated", "expired", "quarantined"]
        },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier"],
          "properties": {
            "tier": {
              "enum": ["constitutional", "governed", "standard", "experimental"]
            }
          }
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["coreVersion", "registryVersion"],
          "properties": {
            "coreVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "registryVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "pluginApiVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "languageAdapter": {
              "type": "string"
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selfVerification": {
          "$ref": "#/$defs/selfVerification"
        }
      }
    },
    "mapRegistryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapId",
        "mapVersion",
        "schemaId",
        "specVersion",
        "schemaPath",
        "status",
        "governance",
        "members",
        "edges",
        "entrypoints",
        "qualityTargets",
        "mapHash"
      ],
      "properties": {
        "mapId": {
          "type": "string",
          "pattern": "^ATM-MAP-\\d{4}$"
        },
        "mapVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaId": {
          "const": "atm.atomicMap"
        },
        "specVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaPath": {
          "type": "string",
          "pattern": "^schemas/.+\\.schema\\.json$"
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/mapMember"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mapEdge"
          }
        },
        "entrypoints": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
          }
        },
        "qualityTargets": {
          "$ref": "#/$defs/mapQualityTargets"
        },
        "mapHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "replacement": {
          "$ref": "#/$defs/mapReplacement"
        },
        "status": {
          "enum": ["draft", "validated", "active", "transitioning", "deprecated", "expired", "quarantined"]
        },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier"],
          "properties": {
            "tier": {
              "enum": ["constitutional", "governed", "standard", "experimental"]
            }
          }
        },
        "semanticFingerprint": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(?:sf:)?sha256:[a-f0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "pendingSfCalculation": {
          "type": "boolean"
        },
        "lineageLogRef": {
          "type": "string",
          "minLength": 1
        },
        "ttl": {
          "type": "integer",
          "minimum": 0
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "mapMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "version"],
      "properties": {
        "atomId": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "role": {
          "enum": ["entry-adapter", "domain-step", "validator", "side-effect", "rollback-adapter"]
        }
      }
    },
    "mapEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "binding"],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "to": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "binding": {
          "type": "string",
          "minLength": 1
        },
        "edgeKind": {
          "enum": ["data-flow", "control-flow", "event-flow", "validation", "fallback", "side-effect", "rollback"]
        }
      }
    },
    "mapReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legacyUris", "mode", "evidenceRefs"],
      "properties": {
        "legacyUris": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^legacy://.+$"
          }
        },
        "mode": {
          "enum": ["draft", "shadow", "canary", "active", "legacy-retired"]
        },
        "evidenceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "mapQualityTargets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "registryVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "specHash", "codeHash", "testHash", "timestamp"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "specHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "codeHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "testHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "semanticFingerprint": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(?:sf:)?sha256:[a-f0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "hashLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "digest", "canonicalization"],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "canonicalization": {
          "enum": ["json-stable-v1", "text-normalized-v1"]
        }
      }
    },
    "selfVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legacyPlanningId",
        "specHash",
        "codeHash",
        "testHash",
        "sourcePaths"
      ],
      "properties": {
        "legacyPlanningId": {
          "type": ["string", "null"],
          "pattern": "^ATM-CORE-\\d{4}$"
        },
        "specHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "codeHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "testHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "sourcePaths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spec", "code", "tests"],
          "properties": {
            "spec": {
              "type": "string",
              "minLength": 1
            },
            "code": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              ]
            },
            "tests": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specPath", "codePaths", "testPaths", "reportPath", "workbenchPath"],
      "properties": {
        "specPath": {
          "type": "string",
          "minLength": 1
        },
        "codePaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testPaths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reportPath": {
          "type": ["string", "null"]
        },
        "workbenchPath": {
          "type": ["string", "null"]
        }
      }
    },
    "sharding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "partPaths", "nextRegistryId"],
      "properties": {
        "strategy": {
          "enum": ["single-document", "external-parts"]
        },
        "partPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextRegistryId": {
          "type": ["string", "null"],
          "pattern": "^registry\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        }
      }
    }
  }
}
