{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/registry.schema.json",
  "title": "ATM Registry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "registryId", "generatedAt", "entries"],
  "properties": {
    "schemaId": {
      "const": "atm.registry"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "registryId": {
      "type": "string",
      "pattern": "^registry\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sharding": {
      "$ref": "#/$defs/sharding"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/registryEntry"
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "registryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atomId",
        "schemaId",
        "specVersion",
        "schemaPath",
        "specPath",
        "hashLock",
        "owner",
        "status",
        "compatibility",
        "evidence",
        "selfVerification"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^atom\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "atomId": {
          "type": "string",
          "pattern": "^atom\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "atomVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaId": {
          "const": "atm.atomicSpec"
        },
        "specVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaPath": {
          "type": "string",
          "pattern": "^schemas/.+\\.schema\\.json$"
        },
        "specPath": {
          "type": "string",
          "minLength": 1
        },
        "hashLock": {
          "$ref": "#/$defs/hashLock"
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "contact"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "contact": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "status": {
          "enum": ["seed", "active", "experimental", "deprecated", "governed"]
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["coreVersion", "registryVersion"],
          "properties": {
            "coreVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "registryVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "pluginApiVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "languageAdapter": {
              "type": "string"
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selfVerification": {
          "$ref": "#/$defs/selfVerification"
        }
      }
    },
    "hashLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "digest", "canonicalization"],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "canonicalization": {
          "enum": ["json-stable-v1", "text-normalized-v1"]
        }
      }
    },
    "selfVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legacyPlanningId",
        "specHash",
        "codeHash",
        "testHash",
        "sourcePaths"
      ],
      "properties": {
        "legacyPlanningId": {
          "type": ["string", "null"],
          "pattern": "^ATM-CORE-\\d{4}$"
        },
        "specHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "codeHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "testHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "sourcePaths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spec", "code", "tests"],
          "properties": {
            "spec": {
              "type": "string",
              "minLength": 1
            },
            "code": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              ]
            },
            "tests": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specPath", "codePaths", "testPaths", "reportPath", "workbenchPath"],
      "properties": {
        "specPath": {
          "type": "string",
          "minLength": 1
        },
        "codePaths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testPaths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reportPath": {
          "type": ["string", "null"]
        },
        "workbenchPath": {
          "type": ["string", "null"]
        }
      }
    },
    "sharding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "partPaths", "nextRegistryId"],
      "properties": {
        "strategy": {
          "enum": ["single-document", "external-parts"]
        },
        "partPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextRegistryId": {
          "type": ["string", "null"],
          "pattern": "^registry\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        }
      }
    }
  }
}