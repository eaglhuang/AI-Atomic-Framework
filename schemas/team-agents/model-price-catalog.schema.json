{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/team-agents/model-price-catalog.schema.json",
  "title": "ATM Model Price Catalog",
  "type": "object",
  "required": ["schemaId", "specVersion", "migration", "catalogVersion", "currency", "immutable", "retrievedAt", "prices"],
  "properties": {
    "schemaId": { "const": "atm.modelPriceCatalog.v1" },
    "specVersion": { "type": "string" },
    "migration": { "type": "object" },
    "catalogVersion": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}\\.[A-Za-z0-9._-]+$" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "immutable": { "const": true },
    "retrievedAt": { "type": "string", "format": "date-time" },
    "prices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/priceRow" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "priceRow": {
      "type": "object",
      "required": [
        "provider",
        "model",
        "billingProduct",
        "plan",
        "region",
        "serviceTier",
        "currency",
        "priceUnit",
        "effectiveAt",
        "retrievedAt",
        "officialSourceUrl",
        "sourceHash",
        "rates"
      ],
      "properties": {
        "provider": { "enum": ["openai", "anthropic", "azure-openai", "claude-code", "gemini", "gemini-direct", "microsoft-foundry"] },
        "model": { "type": "string", "minLength": 1 },
        "billingProduct": { "type": "string", "minLength": 1 },
        "plan": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "serviceTier": { "type": "string", "minLength": 1 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "priceUnit": { "enum": ["per-1m-tokens", "per-request", "per-session", "per-1k-tool-calls", "per-seat-month", "credit"] },
        "effectiveAt": { "type": "string", "format": "date-time" },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "officialSourceUrl": { "type": "string", "format": "uri" },
        "sourceHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "rates": {
          "type": "object",
          "properties": {
            "input": { "type": "number", "minimum": 0 },
            "output": { "type": "number", "minimum": 0 },
            "cacheRead": { "type": "number", "minimum": 0 },
            "cacheWrite": { "type": "number", "minimum": 0 },
            "reasoning": { "type": "number", "minimum": 0 },
            "toolCall": { "type": "number", "minimum": 0 },
            "request": { "type": "number", "minimum": 0 },
            "session": { "type": "number", "minimum": 0 },
            "seatMonth": { "type": "number", "minimum": 0 },
            "creditOverage": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false,
          "minProperties": 1
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
