{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/layer-policy.schema.json",
  "title": "ATM Layer Policy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "rules"],
  "properties": {
    "schemaId": {
      "const": "atm.layerPolicy"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fromLayer", "allowedToLayers"],
      "properties": {
        "fromLayer": {
          "enum": ["core", "compute", "effect", "adapter", "plugin"]
        },
        "allowedToLayers": {
          "type": "array",
          "items": {
            "enum": ["core", "compute", "effect", "adapter", "plugin"]
          },
          "uniqueItems": true
        },
        "explanation": {
          "type": "string"
        }
      }
    }
  }
}
