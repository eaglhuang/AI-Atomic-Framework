{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/governance/closure-packet.schema.json",
  "title": "ATM Closure Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "taskId",
    "targetRepoIdentity",
    "closedByCommand",
    "commandRuns",
    "requiredGates",
    "evidencePath",
    "closedAt",
    "closedByActor"
  ],
  "properties": {
    "schemaId": { "const": "atm.closurePacket.v1" },
    "specVersion": { "const": "0.1.0" },
    "taskId": { "type": "string", "minLength": 1 },
    "targetRepoIdentity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["isFrameworkRepo", "score", "root", "signals"],
      "properties": {
        "isFrameworkRepo": { "const": true },
        "score": { "type": "integer", "minimum": 2 },
        "root": { "type": "string", "minLength": 1 },
        "name": { "type": ["string", "null"] },
        "signals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "targetCommit": { "type": ["string", "null"] },
    "governedTreeSha": { "type": ["string", "null"] },
    "closedByCommand": { "const": "atm tasks close" },
    "commandRuns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "cwd", "exitCode", "stdoutSha256", "stderrSha256", "runnerVersion"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "cwd": { "type": "string", "minLength": 1 },
          "exitCode": { "type": "integer" },
          "stdoutSha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "stderrSha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "runnerVersion": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requiredGates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "teamArtifactHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaId",
        "producedArtifacts",
        "missingArtifacts",
        "retryBudgetStatus",
        "escalationTarget",
        "closeAllowed"
      ],
      "properties": {
        "schemaId": { "const": "atm.teamArtifactHandoffEvidence.v1" },
        "producedArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missingArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "retryBudgetStatus": { "enum": ["within-budget", "escalation-required", "unknown"] },
        "escalationTarget": { "type": ["string", "null"] },
        "closeAllowed": { "type": "boolean" }
      }
    },
    "teamClosureAttestation": {
      "description": "Optional Team Agents runtime attestation for closure review. This metadata enriches review context only; local runtime wrappers are not secure sandbox proof by themselves and command-backed evidence remains required.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaId",
        "teamRunId",
        "runtimeMode",
        "runtimeLanguage",
        "runtimeAdapterId",
        "providerId",
        "sdkId",
        "modelId",
        "runnerKind",
        "runtimeVersion",
        "sandboxPolicyHash",
        "attestationSigner",
        "reviewerIndependence",
        "attestedAt",
        "localRuntimeWrapperIsSecureSandboxProof",
        "commandBackedEvidenceRequired"
      ],
      "properties": {
        "schemaId": { "const": "atm.teamClosureAttestation.v1" },
        "teamRunId": { "type": "string", "minLength": 1 },
        "runtimeMode": { "enum": ["real-agent", "editor-subagent", "broker-only"] },
        "runtimeLanguage": { "type": "string", "minLength": 1 },
        "runtimeAdapterId": { "type": ["string", "null"] },
        "providerId": { "type": ["string", "null"] },
        "sdkId": { "type": ["string", "null"] },
        "modelId": { "type": ["string", "null"] },
        "runnerKind": { "type": "string", "minLength": 1 },
        "runtimeVersion": { "type": ["string", "null"] },
        "sandboxPolicyHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "attestationSigner": { "type": "string", "minLength": 1 },
        "reviewerIndependence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "satisfied",
            "policy",
            "reviewerProviderId",
            "reviewerModelId",
            "reviewerRuntimeAdapterId",
            "reason"
          ],
          "properties": {
            "required": { "type": "boolean" },
            "satisfied": { "type": "boolean" },
            "policy": { "type": "string", "minLength": 1 },
            "reviewerProviderId": { "type": ["string", "null"] },
            "reviewerModelId": { "type": ["string", "null"] },
            "reviewerRuntimeAdapterId": { "type": ["string", "null"] },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "attestedAt": { "type": "string", "minLength": 1 },
        "localRuntimeWrapperIsSecureSandboxProof": { "const": false },
        "commandBackedEvidenceRequired": { "const": true }
      }
    },
    "evidencePath": { "type": "string", "minLength": 1 },
    "closedAt": { "type": "string", "minLength": 1 },
    "closedByActor": { "type": "string", "minLength": 1 }
  }
}
