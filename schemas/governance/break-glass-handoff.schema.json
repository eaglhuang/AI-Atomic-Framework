{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/break-glass-handoff.schema.json",
  "title": "ATM Break-Glass Handoff v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "reason",
    "captainApproval",
    "leadActorId",
    "donorActorId",
    "leadTaskId",
    "donorTaskId",
    "cidCheck",
    "transferredIntent",
    "expandedScope",
    "forbiddenExpansion",
    "acceptanceSplit",
    "rollback"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.breakGlassHandoff.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reason": {
      "enum": ["write-agent-unavailable", "steward-pool-exhausted", "emergency-unblock"]
    },
    "captainApproval": {
      "const": true
    },
    "leadActorId": {
      "type": "string",
      "minLength": 1
    },
    "donorActorId": {
      "type": "string",
      "minLength": 1
    },
    "leadTaskId": {
      "type": "string",
      "minLength": 1
    },
    "donorTaskId": {
      "type": "string",
      "minLength": 1
    },
    "cidCheck": {
      "$ref": "#/$defs/cidCheck"
    },
    "transferredIntent": {
      "type": "string",
      "minLength": 1
    },
    "expandedScope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenExpansion": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceSplit": {
      "$ref": "#/$defs/acceptanceSplit"
    },
    "rollback": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "cidCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "leadAtomCid", "donorAtomCid"],
      "properties": {
        "verdict": {
          "enum": ["disjoint", "conflict"]
        },
        "leadAtomCid": {
          "type": "string",
          "minLength": 1
        },
        "donorAtomCid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acceptanceSplit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leadTaskAcceptance", "donorTaskAcceptance"],
      "properties": {
        "leadTaskAcceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "donorTaskAcceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
