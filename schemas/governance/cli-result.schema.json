{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.dev/schemas/governance/cli-result.schema.json",
  "title": "ATM CLI Result Contract",
  "description": "Machine-readable ATM CLI result envelope used by CLI, skill, and tool-bridge consumers.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ok",
    "command",
    "mode",
    "cwd",
    "messages",
    "evidence",
    "severity",
    "exitCode",
    "blocking",
    "diagnostics"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "cwd": {
      "type": "string",
      "minLength": 1
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["level", "code", "text", "data"],
        "properties": {
          "level": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "pattern": "^ATM_[A-Z0-9_]+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": "object"
          }
        }
      }
    },
    "evidence": {
      "type": "object"
    },
    "nextAction": {
      "type": ["object", "null"]
    },
    "taskIntent": {
      "type": ["object", "null"]
    },
    "userNotice": {
      "type": ["object", "null"]
    },
    "runnerMode": {
      "type": ["object", "null"]
    },
    "frameworkReport": {
      "type": ["object", "null"],
      "description": "Projected framework-mode status payload so tool-first callers can read framework boundaries without digging into evidence.report."
    },
    "frameworkClaim": {
      "type": ["object", "null"],
      "description": "Projected framework-mode claim payload so tool-first callers can inspect claim scope and lock metadata directly."
    },
    "evidenceSummary": {
      "type": ["object", "null"],
      "description": "Projected evidence run/add summary so tool-first callers can read validator passes, artifact paths, and command-backed evidence metadata directly."
    },
    "guardReport": {
      "type": ["object", "null"],
      "description": "Projected guard findings/violations summary for mutation, git, encoding, and related guard surfaces."
    },
    "taskflowReadiness": {
      "type": ["object", "null"],
      "description": "Projected taskflow pre-close/close readiness payload for blockers, closeback path diagnostics, and auto-evidence hints."
    },
    "commitBundle": {
      "type": ["object", "null"],
      "description": "Projected governed git commit bundle diagnostics for task-scoped commit dry-run and write flows."
    },
    "allowedCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockedCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skillGrowth": {
      "type": ["object", "null"],
      "description": "Optional shared growth payload for reusable routing, exception, and learning-loop hints."
    },
    "severity": {
      "type": "string",
      "enum": ["success", "advisory", "blocked", "usage-error", "failure"]
    },
    "exitCode": {
      "type": "integer",
      "minimum": 0
    },
    "blocking": {
      "type": "boolean"
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["errorCodes", "warningCodes", "infoCodes"],
      "properties": {
        "errorCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ATM_[A-Z0-9_]+$"
          }
        },
        "warningCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ATM_[A-Z0-9_]+$"
          }
        },
        "infoCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ATM_[A-Z0-9_]+$"
          }
        }
      }
    }
  }
}
