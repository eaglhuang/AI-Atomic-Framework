{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/content-anchor.schema.json",
  "title": "ATM Content Anchor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "anchorId",
    "baseDigest",
    "filePath",
    "fileDigest",
    "kind",
    "preimageDigest",
    "provenance",
    "confidence"
  ],
  "properties": {
    "schemaId": { "const": "atm.contentAnchor.v1" },
    "specVersion": { "const": "0.1.0" },
    "migration": { "$ref": "#/$defs/migration" },
    "anchorId": { "type": "string", "minLength": 1 },
    "baseDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "filePath": { "type": "string", "minLength": 1 },
    "fileDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "kind": { "enum": ["symbol", "ast-node", "text-context", "file"] },
    "symbolName": { "type": "string", "minLength": 1 },
    "astPath": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "contextBefore": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contextAfter": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preimageDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "location": { "$ref": "#/$defs/location" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "confidence": { "enum": ["high", "medium", "low"] }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": { "enum": ["none", "additive", "breaking"] },
        "fromVersion": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "notes": { "type": "string" }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filePath", "lineStart", "lineEnd"],
      "properties": {
        "filePath": { "type": "string", "minLength": 1 },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapterId", "adapterVersion", "createdAt"],
      "properties": {
        "adapterId": { "type": "string", "minLength": 1 },
        "adapterVersion": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
