{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/retirement-proof.schema.json",
  "title": "ATM Retirement Proof v0.1",
  "description": "Deterministic proof that a replacement map can retire its legacy surface because caller and entrypoint risk has been cleared.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "proofId",
    "mapId",
    "fromMode",
    "toMode",
    "verifiedAt",
    "verifiedBy",
    "callerRiskCleared",
    "entrypointRiskCleared",
    "unresolvedCallers",
    "unresolvedEntrypoints",
    "verificationStatus"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.retirementProof"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "proofId": {
      "type": "string",
      "pattern": "^retirement-proof\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "mapId": {
      "type": "string",
      "pattern": "^ATM-MAP-[A-Z0-9-]+$"
    },
    "mapVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "fromMode": {
      "const": "active"
    },
    "toMode": {
      "const": "legacy-retired"
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verifiedBy": {
      "type": "string",
      "minLength": 1
    },
    "retiredLegacyUris": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "callerRiskCleared": {
      "type": "boolean"
    },
    "entrypointRiskCleared": {
      "type": "boolean"
    },
    "unresolvedCallers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "unresolvedEntrypoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "reviewAdvisoryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    },
    "verificationStatus": {
      "enum": ["passed", "failed"]
    },
    "failureReason": {
      "type": "string"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}