{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/merge-plan.schema.json",
  "title": "ATM Merge Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "mergePlanId",
    "inputProposals",
    "verdict",
    "conflicts",
    "applyMethod",
    "requiredEvidence"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.mergePlan.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "mergePlanId": {
      "type": "string",
      "minLength": 1
    },
    "inputProposals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verdict": {
      "enum": ["parallel-safe", "needs-steward", "blocked-cid-conflict", "blocked-shared-surface", "human-required"]
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflictDetail"
      }
    },
    "applyMethod": {
      "enum": ["patch-apply", "ast-rewrite", "git-three-way-fallback", "steward-authored-final-patch"]
    },
    "requiredEvidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "conflictDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "detail"],
      "properties": {
        "kind": {
          "enum": ["cid", "file-range", "generator", "projection", "validator", "registry", "artifact", "lease"]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
