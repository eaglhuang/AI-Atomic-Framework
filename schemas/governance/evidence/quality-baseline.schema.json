{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/evidence/quality-baseline.schema.json",
  "title": "ATM Quality Baseline Evidence v0.1",
  "required": ["schemaId", "specVersion", "migration"],
  "allOf": [
    {
      "$ref": "https://schemas.ai-atomic-framework.dev/governance/evidence.schema.json"
    },
    {
      "type": "object",
      "required": ["details"],
      "properties": {
        "schemaId": {
          "const": "atm.evidence.qualityBaseline"
        },
        "evidenceType": {
          "const": "quality-baseline"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baselineLabel", "qualityMetrics"],
          "properties": {
            "baselineLabel": {
              "type": "string",
              "minLength": 1
            },
            "qualityMetrics": {
              "$ref": "https://schemas.ai-atomic-framework.dev/test-report/metrics.schema.json"
            }
          }
        }
      }
    }
  ]
}