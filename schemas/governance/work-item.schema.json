{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/work-item.schema.json",
  "title": "ATM Governance Work Item v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "workItemId", "title", "status"],
  "properties": {
    "schemaId": {
      "const": "atm.governanceWorkItem"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "workItemId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["planned", "locked", "running", "verified", "done", "blocked"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "summary": {
      "type": "string"
    },
    "externalRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "id"],
      "properties": {
        "provider": {
          "enum": ["atm-local", "jira", "github-issues", "linear", "notion", "custom"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true,
      "default": []
    },
    "contextMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextFile"
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextFile"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextFile"
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextPattern"
          }
        }
      }
    },
    "acceptanceEvidence": {
      "$ref": "#/$defs/acceptanceEvidenceMap"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contextFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "reason"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contextPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referencePath", "referenceTaskId", "description"],
      "properties": {
        "referencePath": {
          "type": "string",
          "minLength": 1
        },
        "referenceTaskId": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acceptanceEvidenceMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/acceptanceEvidencePredicate"
      }
    },
    "acceptanceEvidencePredicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "claim", "authoritativeSources", "derivationRule", "requiredRealness", "verifier", "negativeControls", "missingDataVerdict", "closureCritical"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "claim": { "type": "string", "minLength": 1 },
        "authoritativeSources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "derivationRule": { "type": "string", "minLength": 1 },
        "requiredRealness": {
          "enum": ["fixture", "unit", "command-smoke", "integration", "sealed-replay", "real-dogfood", "production-ledger"]
        },
        "verifier": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": { "const": "separate-actor" },
                "actorId": { "type": "string", "minLength": 1 }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "policyDigest"],
              "properties": {
                "mode": { "const": "locked-policy" },
                "policyDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
              }
            }
          ]
        },
        "negativeControls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "expectedFailureReason"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
              "expectedFailureReason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "missingDataVerdict": { "const": "inconclusive" },
        "closureCritical": { "type": "boolean" }
      }
    }
  }
}
