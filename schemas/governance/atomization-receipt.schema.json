{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/atomization-receipt.schema.json",
  "title": "ATM Atomization Registration Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "generatedAt",
    "taskId",
    "actorId",
    "eventKind",
    "touchedFiles",
    "affectedAtoms",
    "affectedMaps",
    "validatorOutcome"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.atomizationReceipt.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "eventKind": {
      "type": "string",
      "enum": [
        "atom.registered",
        "atom.updated",
        "atom-map.registered",
        "atom-map.updated",
        "atomization.snapshot-verified"
      ]
    },
    "touchedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "affectedAtoms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "affectedMaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "validatorOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator",
        "passed"
      ],
      "properties": {
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "exitCode": {
          "type": "integer"
        },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "stderrSha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "receiptPath": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
