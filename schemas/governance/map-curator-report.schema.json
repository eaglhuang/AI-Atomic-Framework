{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/map-curator-report.schema.json",
  "title": "ATM Atom Map Curator Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "reportId",
    "generatedAt",
    "curatorName",
    "thresholds",
    "summary",
    "observations",
    "proposalDrafts",
    "empty"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.atomMapCuratorReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "curatorName": {
      "type": "string",
      "minLength": 1
    },
    "thresholds": {
      "$ref": "#/$defs/thresholds"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "callerGraphSignals",
        "inputOutputOverlapSignals",
        "recurringFailureClusterSignals",
        "brokerSplitSuggestionSignals",
        "proposalDrafts",
        "blockedProposalDrafts",
        "patchDrafts",
        "observationOnly"
      ],
      "properties": {
        "callerGraphSignals": {
          "type": "integer",
          "minimum": 0
        },
        "inputOutputOverlapSignals": {
          "type": "integer",
          "minimum": 0
        },
        "recurringFailureClusterSignals": {
          "type": "integer",
          "minimum": 0
        },
        "brokerSplitSuggestionSignals": {
          "type": "integer",
          "minimum": 0
        },
        "proposalDrafts": {
          "type": "integer",
          "minimum": 0
        },
        "blockedProposalDrafts": {
          "type": "integer",
          "minimum": 0
        },
        "patchDrafts": {
          "type": "integer",
          "minimum": 0
        },
        "observationOnly": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    },
    "proposalDrafts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposalDraft"
      }
    },
    "patchDrafts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patchDraft"
      }
    },
    "empty": {
      "type": "boolean"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minCallerGraphOccurrences", "minInputOutputOverlapScore", "minRecurringFailureCount", "minConfidence"],
      "properties": {
        "minCallerGraphOccurrences": {
          "type": "integer",
          "minimum": 1
        },
        "minInputOutputOverlapScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minRecurringFailureCount": {
          "type": "integer",
          "minimum": 1
        },
        "minConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "signalKind", "reasons"],
      "properties": {
        "candidateId": {
          "type": "string",
          "minLength": 1
        },
        "signalKind": {
          "enum": ["caller-graph", "input-output-overlap", "recurring-failure-cluster", "zero-caller-sweep", "broker-split-suggestion"]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "proposalDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "behaviorId",
        "signalKind",
        "targetMapId",
        "sourceEvidenceIds",
        "autoPromoteEligible",
        "proposal"
      ],
      "properties": {
        "candidateId": {
          "type": "string",
          "minLength": 1
        },
        "behaviorId": {
          "enum": ["behavior.compose", "behavior.merge", "behavior.dedup-merge", "behavior.sweep"]
        },
        "signalKind": {
          "enum": ["caller-graph", "input-output-overlap", "recurring-failure-cluster", "zero-caller-sweep"]
        },
        "targetMapId": {
          "type": "string",
          "pattern": "^ATM-MAP-\\d{4}$"
        },
        "sourceEvidenceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "autoPromoteEligible": {
          "type": "boolean"
        },
        "proposal": {
          "$ref": "https://schemas.ai-atomic-framework.dev/upgrade/upgrade-proposal.schema.json"
        }
      }
    },
    "lineRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filePath", "lineStart", "lineEnd"],
      "properties": {
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "lineStart": {
          "type": "integer",
          "minimum": 1
        },
        "lineEnd": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "suggestedAtom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "atomCid", "role", "summary", "sourceRange"],
      "properties": {
        "atomId": {
          "type": "string",
          "minLength": 1
        },
        "atomCid": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["focus", "before", "after"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "sourceRange": {
          "$ref": "#/$defs/lineRange"
        }
      }
    },
    "patchDraftOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "summary"],
      "properties": {
        "op": {
          "enum": ["replace-owner-range", "add-child-atom-row", "rebuild-projection"]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "patchDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "draftKind",
        "signalKind",
        "targetMapId",
        "sourceEvidenceIds",
        "patchFiles",
        "ownerAtomId",
        "conflictRegion",
        "suggestedAtoms",
        "summary",
        "rationale",
        "requiresHumanReview",
        "operations"
      ],
      "properties": {
        "candidateId": {
          "type": "string",
          "minLength": 1
        },
        "draftKind": {
          "const": "atom-map-patch"
        },
        "signalKind": {
          "const": "broker-split-suggestion"
        },
        "targetMapId": {
          "type": "string",
          "pattern": "^ATM-MAP-\\d{4}$"
        },
        "sourceEvidenceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "patchFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "ownerAtomId": {
          "type": "string",
          "minLength": 1
        },
        "conflictRegion": {
          "$ref": "#/$defs/lineRange"
        },
        "suggestedAtoms": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/suggestedAtom"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "requiresHumanReview": {
          "const": true
        },
        "operations": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/patchDraftOperation"
          }
        }
      }
    }
  }
}
