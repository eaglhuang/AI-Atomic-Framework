{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/patch-proposal.schema.json",
  "title": "ATM Patch Proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "proposalId",
    "taskId",
    "actorId",
    "baseCommit",
    "fileBeforeHash",
    "targetFile",
    "atomRefs",
    "anchors",
    "intent",
    "patch",
    "validators",
    "rollback"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.patchProposal.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "proposalId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "transactionId": {
      "type": "string",
      "minLength": 1
    },
    "transactionIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "transaction_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "baseCommit": {
      "type": "string",
      "minLength": 1
    },
    "fileBeforeHash": {
      "type": "string",
      "minLength": 1
    },
    "targetFile": {
      "type": "string",
      "minLength": 1
    },
    "atomRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposalAtomRef"
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patchAnchor"
      }
    },
    "resourceOverlaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resourceOverlap"
      }
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "patch": {
      "type": "string",
      "minLength": 1
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "proposalAtomRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "atomCid"],
      "properties": {
        "atomId": {
          "type": "string",
          "minLength": 1
        },
        "atomCid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "patchAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "hint"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": "string",
          "minLength": 1
        },
        "contentAnchor": {
          "$ref": "#/$defs/contentAnchor"
        }
      }
    },
    "contentAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaId", "specVersion", "migration", "anchorId", "baseDigest", "filePath", "fileDigest", "kind", "preimageDigest", "provenance", "confidence"],
      "properties": {
        "schemaId": { "const": "atm.contentAnchor.v1" },
        "specVersion": { "const": "0.1.0" },
        "migration": { "$ref": "#/$defs/migration" },
        "anchorId": { "type": "string", "minLength": 1 },
        "baseDigest": { "type": "string", "minLength": 1 },
        "filePath": { "type": "string", "minLength": 1 },
        "fileDigest": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["symbol", "ast-node", "text-context", "file"] },
        "symbolName": { "type": "string", "minLength": 1 },
        "astPath": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "contextBefore": { "type": "array", "items": { "type": "string" } },
        "contextAfter": { "type": "array", "items": { "type": "string" } },
        "preimageDigest": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/contentAnchorLocation" },
        "provenance": { "$ref": "#/$defs/contentAnchorProvenance" },
        "confidence": { "enum": ["high", "medium", "low"] }
      }
    },
    "contentAnchorLocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filePath", "lineStart", "lineEnd"],
      "properties": {
        "filePath": { "type": "string", "minLength": 1 },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 }
      }
    },
    "contentAnchorProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapterId", "adapterVersion", "createdAt"],
      "properties": {
        "adapterId": { "type": "string", "minLength": 1 },
        "adapterVersion": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string" }
      }
    },
    "resourceOverlap": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schemaId", "specVersion", "resourceKind", "leftTaskId", "rightTaskId", "verdict", "matcherVersion", "resolverVersion", "provenance", "confidence", "anchors", "intersection", "inputDigest"],
      "properties": {
        "schemaId": { "const": "atm.resourceOverlap.v1" },
        "specVersion": { "const": "0.1.0" },
        "resourceKind": { "type": "string", "minLength": 1 },
        "leftTaskId": { "type": "string", "minLength": 1 },
        "rightTaskId": { "type": "string", "minLength": 1 },
        "verdict": { "enum": ["overlap", "disjoint", "unknown"] },
        "matcherVersion": { "const": "resource-overlap@0.1.0" },
        "resolverVersion": { "const": "resource-key-matcher@0.2.0" },
        "provenance": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "confidence": { "enum": ["high", "medium", "low"] },
        "anchors": { "type": "array" },
        "intersection": { "type": "object" },
        "inputDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    }
  }
}
