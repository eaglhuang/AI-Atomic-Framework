{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/conversation-transcript.schema.json",
  "title": "ATM Redacted Conversation Transcript v0.1",
  "description": "Canonical redacted transcript input for deterministic conversation review extraction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "transcriptId",
    "redacted",
    "containsSensitiveInput",
    "artifactPaths",
    "turns"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.conversationTranscript"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "transcriptId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "window": {
      "type": "string",
      "minLength": 1
    },
    "redacted": {
      "const": true
    },
    "containsSensitiveInput": {
      "type": "boolean"
    },
    "artifactPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "redactionReportPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/turn"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "containsSensitiveInput": {
            "const": true
          }
        },
        "required": ["containsSensitiveInput"]
      },
      "then": {
        "required": ["redactionReportPaths"],
        "properties": {
          "redactionReportPaths": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turnId", "role", "content"],
      "properties": {
        "turnId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["user", "agent", "system"]
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "atomId": {
          "type": "string",
          "minLength": 1
        },
        "atomMapId": {
          "type": "string",
          "minLength": 1
        },
        "skillId": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
