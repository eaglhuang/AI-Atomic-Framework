{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/welcome-lineage.schema.json",
  "title": "ATM Welcome Lineage v0.1",
  "description": "Machine-readable first-touch welcome lifecycle record for ATM onboarding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "firstWelcomedAt",
    "lastWelcomedAt",
    "welcomeCount",
    "constitutionPath",
    "sourceGuardsSha256",
    "installedIntegrations",
    "integrationHealthOk",
    "lastNextAction"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.welcomeLineage"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "firstWelcomedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastWelcomedAt": {
      "type": "string",
      "format": "date-time"
    },
    "welcomeCount": {
      "type": "integer",
      "minimum": 1
    },
    "constitutionPath": {
      "type": "string",
      "minLength": 1
    },
    "sourceGuardsSha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "installedIntegrations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integrationHealthOk": {
      "type": "boolean"
    },
    "lastNextAction": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "status",
        "command",
        "reason"
      ],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "fromVersion",
        "notes"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "none",
            "additive",
            "breaking"
          ]
        },
        "fromVersion": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}