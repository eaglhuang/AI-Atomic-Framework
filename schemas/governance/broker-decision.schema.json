{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/broker-decision.schema.json",
  "title": "ATM Broker Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "intentId",
    "taskId",
    "verdict",
    "lane",
    "conflicts",
    "applyMethod",
    "reason"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.brokerDecision.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "intentId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "enum": ["parallel-safe", "needs-physical-split", "blocked-cid-conflict", "blocked-shared-surface", "serial", "blocked-active-lease"]
    },
    "lane": {
      "enum": ["direct-brokered", "deterministic-composer", "neutral-steward", "serial", "blocked"]
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflictDetail"
      }
    },
    "stewardId": {
      "type": ["string", "null"]
    },
    "applyMethod": {
      "enum": ["patch-apply", "ast-rewrite", "git-three-way-fallback", "steward-authored-final-patch", "none"]
    },
    "reason": {
      "type": "string"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "conflictDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "detail"],
      "properties": {
        "kind": {
          "enum": ["cid", "file-range", "generator", "projection", "validator", "registry", "artifact", "lease"]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
