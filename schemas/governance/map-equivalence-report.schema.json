{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/map-equivalence-report.schema.json",
  "title": "ATM Map Equivalence Report v0.1",
  "description": "Deterministic evidence that an atomic map and its legacy surface behave equivalently for a declared fixture set.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "mapId", "legacyUris", "fixtures", "cases", "summary", "metrics", "artifacts", "evidence", "passed"],
  "properties": {
    "schemaId": {
      "const": "atm.mapEquivalenceReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "pattern": "^map-equivalence\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mapId": {
      "type": "string",
      "pattern": "^ATM-MAP-\\d{4}$"
    },
    "legacyUris": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fixtureRecord"
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/equivalenceCase"
      }
    },
    "knownDivergences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/knownDivergence"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "metrics": {
      "$ref": "https://schemas.ai-atomic-framework.dev/test-report/metrics.schema.json"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRecord"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceRecord"
      }
    },
    "passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "fixtureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixtureId", "path"],
      "properties": {
        "fixtureId": {
          "type": "string",
          "pattern": "^fixture\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "equivalenceCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "input", "expected", "actual", "metric", "evidenceRefs", "passed", "knownDivergence"],
      "properties": {
        "caseId": {
          "type": "string",
          "pattern": "^case\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "input": {
          "$ref": "#/$defs/jsonValue"
        },
        "expected": {
          "$ref": "#/$defs/jsonValue"
        },
        "actual": {
          "$ref": "#/$defs/jsonValue"
        },
        "metric": {
          "$ref": "#/$defs/metricDelta"
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "passed": {
          "type": "boolean"
        },
        "knownDivergence": {
          "type": "boolean"
        }
      }
    },
    "metricDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseline", "current", "delta", "direction", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "type": "number"
        },
        "current": {
          "type": "number"
        },
        "delta": {
          "type": "number"
        },
        "direction": {
          "enum": ["higher-is-better", "lower-is-better", "informational"]
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        }
      }
    },
    "knownDivergence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "reason", "justification", "reviewer", "reviewRef"],
      "properties": {
        "caseId": {
          "type": "string",
          "pattern": "^case\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "justification": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "reviewRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalCases", "passedCases", "failedCases", "knownDivergenceCount"],
      "properties": {
        "totalCases": {
          "type": "integer",
          "minimum": 0
        },
        "passedCases": {
          "type": "integer",
          "minimum": 0
        },
        "failedCases": {
          "type": "integer",
          "minimum": 0
        },
        "knownDivergenceCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifactRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactPath", "artifactKind", "producedBy"],
      "properties": {
        "artifactPath": {
          "type": "string",
          "minLength": 1
        },
        "artifactKind": {
          "enum": ["file", "log", "report", "snapshot"]
        },
        "producedBy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceKind", "summary", "artifactPaths"],
      "properties": {
        "evidenceKind": {
          "enum": ["validation", "review", "metric", "handoff"]
        },
        "signalKind": {
          "enum": ["user-correction", "recurring-failure", "loaded-but-wrong", "novel-technique", "workflow-success", "metric-regression", "rollback-success"]
        },
        "signalScope": {
          "enum": ["host-local", "repo", "atom", "atom-map", "global"]
        },
        "atomMapId": {
          "type": "string",
          "pattern": "^ATM-MAP-\\d{4}$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifactPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "jsonValue": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}