{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/governance/known-bad-versions.schema.json",
  "title": "Known Bad Versions",
  "description": "Release incident response deny-list for published ATM CLI versions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "entries"],
  "properties": {
    "schemaVersion": {
      "const": "atm.knownBadVersions.v0.1"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["versionRange", "reason", "replacementVersion", "severity", "addedAt"],
        "properties": {
          "versionRange": {
            "type": "string",
            "minLength": 1,
            "description": "Exact semver version or a simple comparator range, for example 0.1.0 or >=0.1.0 <0.1.3."
          },
          "reason": {
            "type": "string",
            "minLength": 8
          },
          "replacementVersion": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "addedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
