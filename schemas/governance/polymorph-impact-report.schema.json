{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/polymorph-impact-report.schema.json",
  "title": "ATM Polymorph Impact Report v0.1",
  "description": "Deterministic impact analysis for map promotion when replacement members participate in polymorphic template propagation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "reportId", "generatedAt", "targetMapId", "templateHits", "impactedMapIds", "impactedMaps", "propagation", "artifacts", "evidence", "passed"],
  "properties": {
    "schemaId": {
      "const": "atm.polymorphImpactReport"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "reportId": {
      "type": "string",
      "pattern": "^polymorph-impact\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "targetMapId": {
      "$ref": "#/$defs/mapId"
    },
    "requestedReplacementMode": {
      "enum": ["draft", "shadow", "canary", "active", "legacy-retired"]
    },
    "atomId": {
      "$ref": "#/$defs/atomId"
    },
    "toVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "templateHits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/templateHit"
      }
    },
    "impactedMapIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/mapId"
      }
    },
    "impactedMaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/impactedMap"
      }
    },
    "propagation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/propagationRecord"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRecord"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceRecord"
      }
    },
    "passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "atomId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "mapId": {
      "type": "string",
      "pattern": "^ATM-MAP-\\d{4}$"
    },
    "templateHit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "version", "templateId", "polymorphGroupId"],
      "properties": {
        "atomId": {
          "$ref": "#/$defs/atomId"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "templateId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        },
        "polymorphGroupId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        }
      }
    },
    "impactedMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapId", "templateIds", "matchedMembers"],
      "properties": {
        "mapId": {
          "$ref": "#/$defs/mapId"
        },
        "templateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ATM-POLY-\\d{4}$"
          }
        },
        "matchedMembers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/templateHit"
          }
        }
      }
    },
    "propagatedInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapId", "atomId", "templateId", "polymorphGroupId", "inheritedTemplateVersion", "inheritedBy", "needsRegistryWrite"],
      "properties": {
        "mapId": {
          "$ref": "#/$defs/mapId"
        },
        "atomId": {
          "$ref": "#/$defs/atomId"
        },
        "templateId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        },
        "polymorphGroupId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        },
        "variantKey": {
          "type": "string",
          "minLength": 1
        },
        "inheritedTemplateVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "inheritedBy": {
          "const": "behavior.evolve"
        },
        "needsRegistryWrite": {
          "type": "boolean"
        }
      }
    },
    "propagationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId", "toVersion", "propagatedCount", "propagationMode", "propagatedInstances"],
      "properties": {
        "templateId": {
          "type": "string",
          "pattern": "^ATM-POLY-\\d{4}$"
        },
        "toVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "propagatedCount": {
          "type": "integer",
          "minimum": 0
        },
        "propagationMode": {
          "const": "auto-propagate-all-instances"
        },
        "propagatedInstances": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/propagatedInstance"
          }
        }
      }
    },
    "artifactRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactPath", "artifactKind", "producedBy"],
      "properties": {
        "artifactPath": {
          "type": "string",
          "minLength": 1
        },
        "artifactKind": {
          "enum": ["file", "log", "report", "snapshot"]
        },
        "producedBy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceKind", "summary", "artifactPaths"],
      "properties": {
        "evidenceKind": {
          "enum": ["validation", "review", "metric", "handoff"]
        },
        "signalScope": {
          "enum": ["host-local", "repo", "atom", "atom-map", "global"]
        },
        "atomId": {
          "$ref": "#/$defs/atomId"
        },
        "atomMapId": {
          "$ref": "#/$defs/mapId"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifactPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}