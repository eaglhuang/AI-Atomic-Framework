{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atm.patchEnvelope.v1",
  "title": "ATM Patch Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "envelopeId",
    "taskId",
    "actorId",
    "mode",
    "wipState",
    "snapshotDir",
    "targetFiles",
    "patchText",
    "metadata"
  ],
  "properties": {
    "schemaId": { "const": "atm.patchEnvelope.v1" },
    "specVersion": { "const": "0.1.0" },
    "envelopeId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "actorId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["metadata-only", "textual-diff"] },
    "wipState": { "enum": ["partial", "complete"] },
    "snapshotDir": { "type": "string", "minLength": 1 },
    "targetFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "patchText": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freezeId", "capturedAt", "confidence", "partialReason"],
      "properties": {
        "freezeId": { "type": "string", "minLength": 1 },
        "capturedAt": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["low", "medium", "high"] },
        "partialReason": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
