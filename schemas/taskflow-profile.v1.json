{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskflowProfileV1",
  "description": "Schema for ATM taskflow profile adapter specification v1",
  "type": "object",
  "required": [
    "schemaId",
    "name",
    "capabilities",
    "delegation"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "enum": ["taskflow.profile.v1"]
    },
    "name": {
      "type": "string"
    },
    "capabilities": {
      "type": "object",
      "required": ["supportsDryRun", "supportsWrite"],
      "properties": {
        "supportsDryRun": {
          "type": "boolean"
        },
        "supportsWrite": {
          "type": "boolean"
        }
      }
    },
    "delegation": {
      "type": "object",
      "required": ["hint"],
      "properties": {
        "hint": {
          "type": "string"
        },
        "openerPath": {
          "type": "string"
        }
      }
    }
  }
}
