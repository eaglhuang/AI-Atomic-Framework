    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "templates"
  ],
  "dependencies": {
    "@ai-atomic-framework/core": "0.1.0",
    "@ai-atomic-framework/plugin-sdk": "0.1.0"
  },
  "scripts": {
    "build": "node --strip-types ../../scripts/build-package-dist.ts --package packages/atm-markdown-task-source",
    "test": "node --strip-types ../../scripts/validate-package-skeleton.ts --mode test",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "types": "./dist/index.d.ts"
