{
  "name": "@ai-atomic-framework/atm-markdown-task-source",
  "version": "0.1.0",
  "private": false,
  "description": "Reference ExternalTaskSourcePlugin for parsing markdown task cards.",
  "license": "Apache-2.0",
  "type": "module",
