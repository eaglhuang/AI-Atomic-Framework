{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AtmConfig",
  "description": "Schema for ATM adoption repository-local .atm/config.json configuration",
  "type": "OBJECT",
  "properties": {
    "atomization": {
      "type": "OBJECT",
      "properties": {
        "maxLines": {
          "type": "INTEGER",
          "minimum": 1,
          "default": 600,
          "description": "Repository atom/map/script line cap. Repositories may lower this default; raising it requires an explicit expiring waiver."
        },
        "waiver": {
          "type": "OBJECT",
          "required": [
            "reason",
            "expiresAt"
          ],
          "properties": {
            "reason": {
              "type": "STRING",
              "minLength": 1
            },
            "expiresAt": {
              "type": "STRING",
              "format": "date-time"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "maxLines": {
                "minimum": 601
              }
            },
            "required": [
              "maxLines"
            ]
          },
          "then": {
            "required": [
              "waiver"
            ]
          }
        }
      ]
    },
    "plugins": {
      "type": "OBJECT",
      "properties": {
        "externalTaskSources": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "required": [
              "id",
              "packagePath",
              "enabled",
              "mode"
            ],
            "properties": {
              "id": {
                "type": "STRING"
              },
              "packagePath": {
                "type": "STRING"
              },
              "enabled": {
                "type": "BOOLEAN"
              },
              "mode": {
                "type": "STRING",
                "enum": [
                  "advisory",
                  "enforce",
                  "disabled"
                ]
              }
            }
          }
        }
      }
    }
  }
}
