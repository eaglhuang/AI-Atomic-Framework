{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskflowProfileV1",
  "description": "Schema for ATM taskflow profile adapter specification v1",
  "type": "object",
  "required": [
    "schemaId",
    "id",
    "name",
    "repoLabel",
    "ownerRepo",
    "taskIdPrefix",
    "taskId",
    "template",
    "capabilities",
    "delegation"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "enum": ["taskflow.profile.v1"]
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "repoLabel": {
      "type": "string"
    },
    "ownerRepo": {
      "type": "string"
    },
    "taskIdPrefix": {
      "type": "string"
    },
    "taskId": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string"
        }
      }
    },
    "template": {
      "type": "object",
      "required": ["defaultMarkdown"],
      "properties": {
        "defaultMarkdown": {
          "type": "string"
        },
        "namedTemplates": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "required": ["supportsDryRun", "supportsWrite"],
      "properties": {
        "supportsDryRun": {
          "type": "boolean"
        },
        "supportsWrite": {
          "type": "boolean"
        }
      }
    },
    "delegationDisplayHint": {
      "type": "string"
    },
    "delegation": {
      "type": "object",
      "required": ["hint"],
      "properties": {
        "hint": {
          "type": "string"
        },
        "openerPath": {
          "type": "string"
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allocateTaskId": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "enum": ["host-opener", "fallback"]
                },
                "prefix": {
                  "type": "string"
                },
                "format": {
                  "type": "string"
                }
              }
            },
            "resolveCanonicalOutputPath": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "enum": ["host-opener", "fallback"]
                },
                "pattern": {
                  "type": "string"
                },
                "directory": {
                  "type": "string"
                }
              }
            },
            "rosterSyncPolicy": {
              "enum": ["inline", "follow-up-command", "none"]
            },
            "rosterSync": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "indexPath": {
                  "type": "string"
                }
              }
            },
            "fallbackBehavior": {
              "type": "object",
              "additionalProperties": false,
              "required": ["reason"],
              "properties": {
                "mode": {
                  "enum": ["template-only-fallback", "governed-fallback"]
                },
                "reason": {
                  "type": "string"
                },
                "missingPrerequisites": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "writerInvocation": {
          "type": "object",
          "properties": {
            "describeOnly": {
              "type": "boolean"
            },
            "displayHint": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
