{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/scope-lock.schema.json",
  "title": "ATM Governance Scope Lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "workItemId", "lockedBy", "lockedAt", "files"],
  "properties": {
    "schemaId": {
      "const": "atm.governanceScopeLock"
    },
    "specVersion": {
      "enum": ["0.1.0", "0.2.0"]
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "workItemId": {
      "$ref": "#/$defs/workItemId"
    },
    "lockedBy": {
      "type": "string",
      "minLength": 1
    },
    "lockedAt": {
      "type": "string",
      "format": "date-time"
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "leaseId": {
      "type": "string",
      "minLength": 1
    },
    "heartbeatAt": {
      "type": "string",
      "format": "date-time"
    },
    "ttlSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "reason": {
      "type": "string"
    },
    "selectors": {
      "$ref": "#/$defs/selectors"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "specVersion": {
            "const": "0.1.0"
          }
        },
        "required": ["specVersion"]
      },
      "then": {
        "not": {
          "required": ["selectors"]
        }
      }
    },
    {
      "if": {
        "properties": {
          "specVersion": {
            "const": "0.2.0"
          }
        },
        "required": ["specVersion"]
      },
      "then": {
        "required": ["selectors"]
      }
    }
  ],
  "$defs": {
    "workItemId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "mapId": {
      "type": "string",
      "pattern": "^ATM-MAP-\\d{4}$"
    },
    "atomId": {
      "type": "string",
      "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
    },
    "legacyUri": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9+.-]*://.+$"
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "selectorEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "$ref": "#/$defs/atomId"
        },
        "to": {
          "$ref": "#/$defs/atomId"
        },
        "edgeKind": {
          "enum": ["data-flow", "control-flow", "event-flow", "validation", "fallback", "side-effect", "rollback"]
        }
      }
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mapId": {
          "$ref": "#/$defs/mapId"
        },
        "mapMembers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/atomId"
          },
          "uniqueItems": true
        },
        "mapEdges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectorEdge"
          }
        },
        "mapEntrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/atomId"
          },
          "uniqueItems": true
        },
        "legacyUris": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/legacyUri"
          },
          "uniqueItems": true
        }
      },
      "minProperties": 1
    }
  }
}
