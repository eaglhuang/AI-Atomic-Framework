{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atm.teamAgentPermissionPolicy.schema.json",
  "title": "ATM Team Agent Permission Policy",
  "type": "object",
  "required": [
    "schemaId",
    "repoPolicyId",
    "allowedPermissions",
    "vendorPermissions",
    "defaultDecision"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.teamPermissionPolicy.v1"
    },
    "repoPolicyId": {
      "type": "string",
      "minLength": 1
    },
    "allowedPermissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "vendorPermissions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "defaultDecision": {
      "enum": ["allow", "deny"]
    }
  },
  "additionalProperties": false
}
