{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/decomposition-plan.schema.json",
  "title": "ATM Decomposition Plan v0.1",
  "description": "Deterministic plan that decomposes a large feature into a canonical replacement-capable atomic map.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "specVersion", "migration", "legacyUris", "proposedMapId", "proposedMembers", "proposedEdges", "entrypoints", "notes"],
  "properties": {
    "schemaId": {
      "const": "atm.decompositionPlan"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "planId": {
      "type": "string",
      "pattern": "^decomposition-plan\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mapVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "legacyUris": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proposedMapId": {
      "type": "string",
      "pattern": "^ATM-MAP-\\d{4}$"
    },
    "proposedMembers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/memberRecord"
      }
    },
    "proposedEdges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edgeRecord"
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
      }
    },
    "qualityTargets": {
      "$ref": "#/$defs/qualityTargets"
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "memberRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "version"],
      "properties": {
        "atomId": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "role": {
          "enum": ["entry-adapter", "domain-step", "validator", "side-effect", "rollback-adapter"]
        }
      }
    },
    "edgeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "binding"],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "to": {
          "type": "string",
          "pattern": "^ATM-[A-Z][A-Z0-9]*-\\d{4}$"
        },
        "binding": {
          "type": "string",
          "minLength": 1
        },
        "edgeKind": {
          "enum": ["data-flow", "control-flow", "event-flow", "validation", "fallback", "side-effect", "rollback"]
        }
      }
    },
    "qualityTargets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  }
}