{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/context-summary.schema.json",
  "title": "ATM Context Summary v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "workItemId",
    "summary",
    "nextActions",
    "generatedAt"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.contextSummary"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "summaryId": {
      "type": "string",
      "minLength": 1
    },
    "workItemId": {
      "type": "string",
      "pattern": "^(?:ATM-[A-Z][A-Z0-9]*-\\d{4}|BOOTSTRAP-\\d{4})$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "artifactPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "evidencePaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "reportPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "authoredBy": {
      "type": "string",
      "minLength": 1
    },
    "handoffKind": {
      "enum": ["bootstrap", "self-host-alpha", "continuation", "budget-hard-stop"]
    },
    "continuationGoal": {
      "type": "string",
      "minLength": 1
    },
    "resumePrompt": {
      "type": "string",
      "minLength": 1
    },
    "resumeCommand": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "budgetDecision": {
      "enum": ["pass", "summarize-before-continue", "hard-stop"]
    },
    "hardStop": {
      "type": "boolean"
    },
    "summaryMarkdownPath": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}