{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/write-intent.schema.json",
  "title": "ATM Write Intent v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "taskId",
    "actorId",
    "baseCommit",
    "targetFiles",
    "atomRefs",
    "sharedSurfaces",
    "requestedLane"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.writeIntent.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "baseCommit": {
      "type": "string",
      "minLength": 1
    },
    "targetFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "atomRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/atomRef"
      }
    },
    "sharedSurfaces": {
      "$ref": "#/$defs/sharedSurfaces"
    },
    "requestedLane": {
      "enum": ["auto", "direct-brokered", "deterministic-composer", "neutral-steward", "serial", "blocked"]
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "atomRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId", "atomCid", "operation"],
      "properties": {
        "atomId": {
          "type": "string",
          "minLength": 1
        },
        "atomCid": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "enum": ["create", "modify", "delete"]
        }
      }
    },
    "sharedSurfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generators", "projections", "registries", "validators", "artifacts"],
      "properties": {
        "generators": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "projections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "registries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
