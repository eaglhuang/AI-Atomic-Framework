{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/governance/broker-conflict-resolution.schema.json",
  "title": "ATM Broker Conflict Resolution v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "resolutionId",
    "createdAt",
    "primaryTaskId",
    "conflictingTaskIds",
    "sharedPaths",
    "decisionClass",
    "decisionReason",
    "violationStatus",
    "releaseOrder",
    "currentAllowedTaskId",
    "blockedTaskIds",
    "artifactType",
    "statusCode",
    "brokerTicket",
    "authorityGeneration",
    "authorityDigest",
    "conflictFiles",
    "authorizationResourceKind",
    "authorizationOperation",
    "authorizationGate"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.brokerConflictResolution.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "resolutionId": {
      "type": "string",
      "pattern": "^BCR-[a-z0-9]+$"
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "primaryTaskId": {
      "type": "string",
      "minLength": 1
    },
    "conflictingTaskIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sharedPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "decisionClass": {
      "enum": ["serial-release", "human-signoff-required", "adr-required", "blocked"]
    },
    "decisionReason": {
      "type": "string",
      "minLength": 1
    },
    "violationStatus": {
      "enum": ["broker-conflict-blocked", "resolution-issued", "resolved"]
    },
    "releaseOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "currentAllowedTaskId": {
      "type": ["string", "null"]
    },
    "blockedTaskIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifactType": {
      "const": "atm.brokerConflictResolution.v1"
    },
    "statusCode": {
      "const": "broker-conflict-blocked"
    },
    "brokerTicket": {
      "$ref": "#/$defs/brokerTicket"
    },
    "authorityGeneration": {
      "type": "integer",
      "minimum": 0
    },
    "authorityDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "conflictFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "authorizationResourceKind": {
      "enum": ["path", "atom", "surface", "range"]
    },
    "authorizationOperation": {
      "type": "string",
      "minLength": 1
    },
    "authorizationGate": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "brokerTicket": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaId",
        "specVersion",
        "ticketId",
        "taskId",
        "actorId",
        "state",
        "generation",
        "authorityGeneration",
        "authorityDigest",
        "authorizationGrants"
      ],
      "properties": {
        "schemaId": { "const": "atm.brokerTicket.v1" },
        "specVersion": { "const": "0.1.0" },
        "ticketId": { "type": "string", "minLength": 1 },
        "taskId": { "type": "string", "minLength": 1 },
        "actorId": { "type": "string", "minLength": 1 },
        "state": {
          "enum": [
            "created",
            "collecting",
            "ready",
            "composing",
            "revalidation-required",
            "queued",
            "wakeup-pending",
            "executing",
            "released",
            "cancelled",
            "adoptable",
            "reconcile-required"
          ]
        },
        "generation": { "type": "integer", "minimum": 0 },
        "authorityGeneration": { "type": "integer", "minimum": 0 },
        "authorityDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "authorizationGrants": {
          "type": "array",
          "items": { "$ref": "#/$defs/authorizationGrant" }
        }
      }
    },
    "authorizationGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grantId",
        "resourceKind",
        "resourceKeys",
        "operations",
        "gates",
        "authorityGeneration",
        "authorityDigest"
      ],
      "properties": {
        "grantId": { "type": "string", "minLength": 1 },
        "resourceKind": { "enum": ["path", "atom", "surface", "range"] },
        "resourceKeys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "authorityGeneration": { "type": "integer", "minimum": 0 },
        "authorityDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    }
  }
}
