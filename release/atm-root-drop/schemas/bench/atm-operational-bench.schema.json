{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/bench/atm-operational-bench.schema.json",
  "title": "ATM OperationalBench Summary",
  "type": "object",
  "required": [
    "schemaId",
    "benchFamily",
    "benchName",
    "benchVersion",
    "seed",
    "profile",
    "warmup",
    "repeat",
    "concurrency",
    "scenarioCount",
    "resultRows",
    "spanStats",
    "scenarioSpanStats",
    "recoveryMetrics",
    "nullMetricReasons",
    "notes"
  ],
  "properties": {
    "schemaId": { "const": "atm.operationalBenchSummary.v1" },
    "benchFamily": { "const": "ATM Bench" },
    "benchName": { "const": "ATM OperationalBench" },
    "benchVersion": { "const": "0.1" },
    "seed": { "type": "integer", "minimum": 0 },
    "profile": { "enum": ["smoke", "paper", "extended"] },
    "warmup": { "type": "integer", "minimum": 0 },
    "repeat": { "type": "integer", "minimum": 1 },
    "concurrency": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 1 }
    },
    "scenarioCount": { "type": "integer", "minimum": 1 },
    "resultRows": { "type": "integer", "minimum": 1 },
    "trackCounts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "blockedCaseCounts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "routeCounts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "spanStats": {
      "type": "object",
      "required": [
        "diffConstructionMs",
        "mutationRequestConstructionMs",
        "admissionDecisionMs",
        "composerPlanMs",
        "stewardDryRunMs",
        "stewardApplyMs",
        "validatorMs",
        "gitAdmitDryRunMs",
        "casMismatchRecoveryMs",
        "queueWaitMs",
        "totalScenarioMs"
      ],
      "additionalProperties": { "$ref": "#/$defs/stats" }
    },
    "scenarioSpanStats": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "$ref": "#/$defs/stats" }
      }
    },
    "recoveryMetrics": {
      "type": "object",
      "required": [
        "preservedIntentSalvageRate",
        "terminalFailClosedRate",
        "overSerializationRate",
        "fullRegenerationRate",
        "fullRegenerationNote"
      ],
      "properties": {
        "preservedIntentSalvageRate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "terminalFailClosedRate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "overSerializationRate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "fullRegenerationRate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "fullRegenerationNote": { "type": "string" }
      },
      "additionalProperties": false
    },
    "nullMetricReasons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioId", "metric", "reason"],
        "properties": {
          "scenarioId": { "type": "string", "minLength": 1 },
          "metric": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullableNumber": { "type": ["number", "null"], "minimum": 0 },
    "stats": {
      "type": "object",
      "required": ["count", "min", "max", "mean", "stddev", "p50", "p95", "p99"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "min": { "$ref": "#/$defs/nullableNumber" },
        "max": { "$ref": "#/$defs/nullableNumber" },
        "mean": { "$ref": "#/$defs/nullableNumber" },
        "stddev": { "$ref": "#/$defs/nullableNumber" },
        "p50": { "$ref": "#/$defs/nullableNumber" },
        "p95": { "$ref": "#/$defs/nullableNumber" },
        "p99": { "$ref": "#/$defs/nullableNumber" }
      },
      "additionalProperties": false
    }
  }
}
