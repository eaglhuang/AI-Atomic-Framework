{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/broker/conflict-key.schema.json",
  "title": "ATM Broker Conflict Key v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "scope",
    "key"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.conflictKey.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "scope": {
      "enum": ["file", "record", "range", "line", "scalar", "semantic"]
    },
    "key": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
