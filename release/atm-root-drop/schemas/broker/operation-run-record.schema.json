{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/broker/operation-run-record.schema.json",
  "title": "ATM Broker Operation Run Record Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "runId",
    "planId",
    "records"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.brokerOperationRunRecordEnvelope.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runRecord"
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaId",
        "specVersion",
        "migration",
        "runId",
        "planId",
        "request_identity",
        "actor_ids",
        "request_files",
        "adapter_choice",
        "applied_files",
        "lane_decision",
        "merge_verdict",
        "evidence_path"
      ],
      "properties": {
        "schemaId": {
          "const": "atm.brokerOperationRunRecord.v1"
        },
        "specVersion": {
          "const": "0.1.0"
        },
        "migration": {
          "$ref": "#/$defs/migration"
        },
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "planId": {
          "type": "string",
          "minLength": 1
        },
        "request_identity": {
          "$ref": "#/$defs/stringList"
        },
        "actor_ids": {
          "$ref": "#/$defs/stringList"
        },
        "request_files": {
          "$ref": "#/$defs/stringList"
        },
        "adapter_choice": {
          "type": "string",
          "minLength": 1
        },
        "applied_files": {
          "$ref": "#/$defs/stringList"
        },
        "lane_decision": {
          "type": "string",
          "minLength": 1
        },
        "merge_verdict": {
          "enum": ["mergeable", "conflict", "commutative-merge"]
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "commit_sha": {
          "type": "string",
          "minLength": 1
        },
        "transaction_ids": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  }
}
