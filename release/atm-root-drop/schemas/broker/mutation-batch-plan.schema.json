{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/broker/mutation-batch-plan.schema.json",
  "title": "ATM Broker Mutation Batch Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "specVersion",
    "migration",
    "planId",
    "batches",
    "queued",
    "blocked"
  ],
  "properties": {
    "schemaId": {
      "const": "atm.mutationBatchPlan.v1"
    },
    "specVersion": {
      "const": "0.1.0"
    },
    "migration": {
      "$ref": "#/$defs/migration"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "batches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/batch"
      }
    },
    "queued": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "fromVersion", "notes"],
      "properties": {
        "strategy": {
          "enum": ["none", "additive", "breaking"]
        },
        "fromVersion": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "conflictKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaId", "specVersion", "migration", "scope", "key"],
      "properties": {
        "schemaId": {
          "const": "atm.conflictKey.v1"
        },
        "specVersion": {
          "const": "0.1.0"
        },
        "migration": {
          "$ref": "#/$defs/migration"
        },
        "scope": {
          "enum": ["file", "record", "range", "line", "scalar", "semantic"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filePath", "adapterId", "verdict", "requestIds", "conflictKeys"],
      "properties": {
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "adapterId": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "enum": ["mergeable", "commutative-merge"]
        },
        "requestIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflictKeys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conflictKey"
          }
        }
      }
    }
  }
}
