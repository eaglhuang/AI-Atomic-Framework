{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-atomic-framework.dev/team-agents/agent-report.schema.json",
  "title": "AgentReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "status", "filesRead", "filesChanged", "commandsRun", "findings", "blockers", "recommendation", "handoff"],
  "properties": {
    "role": { "type": "string", "minLength": 1 },
    "status": { "enum": ["done", "blocked", "partial", "no-op"] },
    "filesRead": { "type": "array", "items": { "type": "string" } },
    "filesChanged": { "type": "array", "items": { "type": "string" } },
    "commandsRun": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "recommendation": { "enum": ["close", "continue", "escalate"] },
    "handoff": { "type": "string", "minLength": 1 }
  }
}
