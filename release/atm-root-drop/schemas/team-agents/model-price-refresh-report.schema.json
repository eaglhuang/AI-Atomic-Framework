{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.local/schemas/team-agents/model-price-refresh-report.schema.json",
  "title": "ATM Model Price Refresh Report",
  "type": "object",
  "required": ["schemaId", "catalogVersion", "retrievedAt", "sourceCount", "priceRowCount", "missingOfficialSourceRows", "rows"],
  "properties": {
    "schemaId": { "const": "atm.modelPriceRefreshReport.v1" },
    "catalogVersion": { "type": "string" },
    "retrievedAt": { "type": "string" },
    "sourceCount": { "type": "integer", "minimum": 1 },
    "priceRowCount": { "type": "integer", "minimum": 1 },
    "missingOfficialSourceRows": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "model", "officialSourceUrl", "sourceHash", "hasUsdRate"],
        "properties": {
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "officialSourceUrl": { "type": "string", "format": "uri" },
          "sourceHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "hasUsdRate": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
