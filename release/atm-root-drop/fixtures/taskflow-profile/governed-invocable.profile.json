{
  "schemaId": "taskflow.profile.v1",
  "id": "governed-invocable-profile-v1",
  "name": "Governed Invocable Profile",
  "repoLabel": "Governed Planning Repo",
  "ownerRepo": "governed-planning-repo",
  "taskIdPrefix": "TASK-GOVERNED",
  "taskId": {
    "format": "TASK-GOVERNED-NNNN"
  },
  "template": {
    "defaultMarkdown": "# ${taskId} ${title}\n\n## Goal\n${description}"
  },
  "capabilities": {
    "supportsDryRun": true,
    "supportsWrite": false
  },
  "delegationDisplayHint": "Host opener may execute governed writes through taskflow open.",
  "delegation": {
    "hint": "Host opener supplies numbering and output policy through an invocable writer contract.",
    "openerPath": "tools/task-card-opener.js",
    "policy": {
      "allocateTaskId": {
        "mode": "host-opener",
        "prefix": "TASK-GOVERNED",
        "format": "TASK-GOVERNED-NNNN"
      },
      "resolveCanonicalOutputPath": {
        "mode": "host-opener",
        "pattern": "docs/tasks/${taskId}.task.md",
        "directory": "docs/tasks"
      },
      "rosterSyncPolicy": "follow-up-command",
      "rosterSync": {
        "indexPath": "docs/tasks/README.md"
      },
      "fallbackBehavior": {
        "mode": "template-only-fallback",
        "reason": "Host opener remains responsible for fallback when host policy is not invocable.",
        "missingPrerequisites": [
          "host opener not invoked"
        ]
      }
    },
    "writerInvocation": {
      "describeOnly": false,
      "displayHint": "node tools/task-card-opener.js --write --task ${taskId}"
    }
  }
}
