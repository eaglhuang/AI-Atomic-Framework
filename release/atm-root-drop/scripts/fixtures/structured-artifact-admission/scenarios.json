        {
          "proposalId": "sa.toml.01.a",
          "atomId": "TOML-TOOL-BLACK",
          "atomCid": "cid-toml-tool-black",
          "patch": "--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -4,1 +4,1 @@\n-line-length = 88\n+line-length = 100\n",
          "intent": "Adjust Black line length."
        },
        {
          "proposalId": "sa.toml.01.b",
          "atomId": "TOML-TOOL-PYTEST",
          "atomCid": "cid-toml-tool-pytest",
          "patch": "--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -12,1 +12,1 @@\n-addopts = \"-q\"\n+addopts = \"-q -ra\"\n",
          "intent": "Adjust pytest flags."
        }
      ]
    },
    {
      "id": "toml-config-shared-table-blocked",
      "format": "toml",
      "family": "toml-config",
      "kind": "compose",
      "targetFile": "pyproject.toml",
      "description": "Two TOML edits targeting the same dependency entry should block.",
      "expectedVerdict": "blocked-cid-conflict",
      "proposals": [
        {
          "proposalId": "sa.toml.02.a",
          "atomId": "TOML-DEPS-FASTAPI",
          "atomCid": "cid-toml-deps-fastapi",
          "patch": "--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -20,1 +20,1 @@\n-fastapi = \"^0.136.3\"\n+fastapi = \"^0.137.0\"\n",
          "intent": "Upgrade FastAPI dependency."
        },
        {
          "proposalId": "sa.toml.02.b",
          "atomId": "TOML-DEPS-FASTAPI",
          "atomCid": "cid-toml-deps-fastapi",
          "patch": "--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -20,1 +20,1 @@\n-fastapi = \"^0.136.3\"\n+fastapi = \"^0.136.3,<0.137.0\"\n",
          "intent": "Pin FastAPI upper bound."
        }
      ]
    },
