        {
          "proposalId": "sa.openapi.01.a",
          "atomId": "OPENAPI-PATH-ITEMS",
          "atomCid": "cid-openapi-path-items",
          "patch": "--- a/openapi/openapi.yaml\n+++ b/openapi/openapi.yaml\n@@ -15,1 +15,1 @@\n-      summary: List items\n+      summary: List catalog items\n",
          "intent": "Update /items summary."
        },
        {
          "proposalId": "sa.openapi.01.b",
          "atomId": "OPENAPI-PATH-USERS",
          "atomCid": "cid-openapi-path-users",
          "patch": "--- a/openapi/openapi.yaml\n+++ b/openapi/openapi.yaml\n@@ -42,1 +42,1 @@\n-      summary: List users\n+      summary: List active users\n",
          "intent": "Update /users summary."
        }
      ]
    },
