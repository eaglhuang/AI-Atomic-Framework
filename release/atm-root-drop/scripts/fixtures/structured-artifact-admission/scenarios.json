          "atomCid": "cid-openapi-post-items",
          "patch": "--- a/openapi/openapi.yaml\n+++ b/openapi/openapi.yaml\n@@ -28,1 +28,1 @@\n-      operationId: createItem\n+      operationId: createCatalogItem\n",
          "intent": "Rename create item operation."
        },
        {
          "proposalId": "sa.openapi.02.b",
          "atomId": "OPENAPI-POST-ITEMS",
          "atomCid": "cid-openapi-post-items",
          "patch": "--- a/openapi/openapi.yaml\n+++ b/openapi/openapi.yaml\n@@ -28,1 +28,1 @@\n-      operationId: createItem\n+      operationId: addItem\n",
          "intent": "Alternative operation rename."
        }
      ]
    },
