{
  "schemaId": "atm.structuredArtifactAdmissionScenarioSet.v1",
  "scenarios": [
    {
      "id": "json-manifest-disjoint-keys",
      "format": "json",
      "family": "json-manifest",
      "kind": "compose",
      "targetFile": "configs/project-manifest.json",
      "description": "Two manifest edits touch disjoint top-level keys and should remain parallel-safe.",
      "expectedVerdict": "parallel-safe",
      "proposals": [
        {
          "proposalId": "sa.json.01.a",
          "atomId": "JSON-MANIFEST-NAME",
          "atomCid": "cid-json-manifest-name",
          "patch": "--- a/configs/project-manifest.json\n+++ b/configs/project-manifest.json\n@@ -1,1 +1,1 @@\n-\"name\": \"npc-brain\"\n+\"name\": \"npc-brain-v2\"\n",
          "intent": "Update manifest name."
        },
        {
          "proposalId": "sa.json.01.b",
          "atomId": "JSON-MANIFEST-VERSION",
          "atomCid": "cid-json-manifest-version",
          "patch": "--- a/configs/project-manifest.json\n+++ b/configs/project-manifest.json\n@@ -5,1 +5,1 @@\n-\"version\": \"1.0.0\"\n+\"version\": \"1.1.0\"\n",
          "intent": "Update manifest version."
        }
      ]
    },
    {
      "id": "json-manifest-shared-key-blocked",
      "format": "json",
      "family": "json-manifest",
      "kind": "compose",
      "targetFile": "configs/project-manifest.json",
      "description": "Two manifest edits target the same scripts.install key and should block.",
      "expectedVerdict": "blocked-cid-conflict",
      "proposals": [
        {
          "proposalId": "sa.json.02.a",
          "atomId": "JSON-MANIFEST-INSTALL",
          "atomCid": "cid-json-manifest-install",
          "patch": "--- a/configs/project-manifest.json\n+++ b/configs/project-manifest.json\n@@ -9,1 +9,1 @@\n-\"install\": \"npm ci\"\n+\"install\": \"npm ci --ignore-scripts\"\n",
          "intent": "Harden install script."
        },
        {
          "proposalId": "sa.json.02.b",
          "atomId": "JSON-MANIFEST-INSTALL",
          "atomCid": "cid-json-manifest-install",
          "patch": "--- a/configs/project-manifest.json\n+++ b/configs/project-manifest.json\n@@ -9,1 +9,1 @@\n-\"install\": \"npm ci\"\n+\"install\": \"pnpm install --frozen-lockfile\"\n",
          "intent": "Switch installer."
        }
      ]
    },
    {
      "id": "json-manifest-readwrite-serial",
      "format": "json",
      "family": "json-manifest",
      "kind": "registry",
      "targetFile": "configs/project-manifest.json",
      "description": "A new manifest write depends on an active dependencyVersions key and should serialize.",
      "expectedVerdict": "serial",
      "newIntent": {
        "taskId": "TASK-SA-JSON-03",
        "actorId": "structured-bench",
        "atomId": "JSON-MANIFEST-SCRIPTS",
        "atomCid": "cid-json-manifest-scripts",
        "readAtoms": ["JSON-MANIFEST-DEPS", "cid-json-manifest-deps"]
      },
      "activeIntent": {
        "taskId": "TASK-SA-JSON-BASE",
        "actorId": "seed-agent",
        "file": "configs/project-manifest.json",
        "atomId": "JSON-MANIFEST-DEPS",
        "atomCid": "cid-json-manifest-deps"
      }
    },
    {
      "id": "yaml-workflow-disjoint-jobs",
      "format": "yaml",
      "family": "yaml-workflow",
      "kind": "compose",
      "targetFile": ".github/workflows/ci.yml",
      "description": "Workflow edits touching separate jobs should remain parallel-safe.",
      "expectedVerdict": "parallel-safe",
      "proposals": [
        {
          "proposalId": "sa.yaml.01.a",
          "atomId": "YAML-WORKFLOW-LINT",
          "atomCid": "cid-yaml-workflow-lint",
          "patch": "--- a/.github/workflows/ci.yml\n+++ b/.github/workflows/ci.yml\n@@ -10,1 +10,1 @@\n-      run: npm run lint\n+      run: npm run lint -- --max-warnings=0\n",
          "intent": "Harden lint job."
        },
        {
          "proposalId": "sa.yaml.01.b",
          "atomId": "YAML-WORKFLOW-TEST",
          "atomCid": "cid-yaml-workflow-test",
          "patch": "--- a/.github/workflows/ci.yml\n+++ b/.github/workflows/ci.yml\n@@ -22,1 +22,1 @@\n-      run: npm test\n+      run: npm test -- --runInBand\n",
          "intent": "Adjust test job."
        }
      ]
    },
    {
      "id": "yaml-workflow-shared-job-blocked",
      "format": "yaml",
      "family": "yaml-workflow",
      "kind": "compose",
      "targetFile": ".github/workflows/ci.yml",
      "description": "Workflow edits targeting the same deploy step should block.",
      "expectedVerdict": "blocked-cid-conflict",
      "proposals": [
        {
          "proposalId": "sa.yaml.02.a",
          "atomId": "YAML-WORKFLOW-DEPLOY",
          "atomCid": "cid-yaml-workflow-deploy",
          "patch": "--- a/.github/workflows/ci.yml\n+++ b/.github/workflows/ci.yml\n@@ -30,1 +30,1 @@\n-      run: npm run deploy\n+      run: npm run deploy -- --dry-run\n",
          "intent": "Dry-run deploy."
        },
        {
          "proposalId": "sa.yaml.02.b",
          "atomId": "YAML-WORKFLOW-DEPLOY",
          "atomCid": "cid-yaml-workflow-deploy",
          "patch": "--- a/.github/workflows/ci.yml\n+++ b/.github/workflows/ci.yml\n@@ -30,1 +30,1 @@\n-      run: npm run deploy\n+      run: npm run deploy -- --region us-east-1\n",
          "intent": "Pin deploy region."
        }
      ]
    },
    {
      "id": "yaml-workflow-readwrite-serial",
      "format": "yaml",
      "family": "yaml-workflow",
      "kind": "registry",
      "targetFile": ".github/workflows/ci.yml",
      "description": "A workflow matrix write depends on an active cache strategy section and should serialize.",
      "expectedVerdict": "serial",
      "newIntent": {
        "taskId": "TASK-SA-YAML-03",
        "actorId": "structured-bench",
        "atomId": "YAML-WORKFLOW-MATRIX",
        "atomCid": "cid-yaml-workflow-matrix",
        "readAtoms": ["YAML-WORKFLOW-CACHE", "cid-yaml-workflow-cache"]
      },
      "activeIntent": {
        "taskId": "TASK-SA-YAML-BASE",
        "actorId": "seed-agent",
        "file": ".github/workflows/ci.yml",
        "atomId": "YAML-WORKFLOW-CACHE",
        "atomCid": "cid-yaml-workflow-cache"
      }
    },
    {
