{
  "schemaId": "atm.runnerBuildScope.v1",
  "specVersion": "0.1.0",
  "policy": {
    "mode": "runner-sync-steward-v1",
    "generatedArtifactWriter": "single-writer-steward",
    "sourceAgentRule": "Source agents may change runner-affecting source and mark runner-sync-needed, but must not publish release/** artifacts."
  },
  "runnerAffectingSourceRoots": [
    "packages/core/src/",
    "packages/cli/src/",
    "packages/plugin-governance-local/src/",
    "packages/adapter-*/src/",
    "packages/adapters/*/src/",
    "packages/agent-pack-*/src/",
    "packages/language-bindings/*/src/",
    "packages/plugin-behavior-pack/src/",
    "packages/plugins/*/src/",
    "integrations/",
    "templates/agent-pack/",
    "schemas/",
    "scripts/AtmCore/"
  ],
  "buildChainScripts": [
    "scripts/build-package-dist.ts",
    "scripts/build-root-drop-release.ts",
    "scripts/build-onefile-release.ts"
  ],
  "buildConfigPaths": [
    "package.json",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "rootLaunchers": [
    "atm.mjs",
    "atm.dev.mjs"
  ],
  "schemaRoots": [
    "schemas/"
  ],
  "generatedArtifacts": [
    "release/atm-root-drop/",
    "release/atm-onefile/",
    "release/atm-onefile/atm.mjs",
    "release/atm-onefile/release-manifest.json",
    "release/atm-root-drop/release-manifest.json"
  ],
  "nonCorePlanningUtilities": [
    "docs/",
    "examples/",
    "atomic_workbench/",
    ".atm/history/",
    ".atm/runtime/"
  ]
}
