{
  "$schema": "atm.rootDropWrappers.v0.1",
  "_comment": "Single source of truth for the 7 root-drop ATM CLI wrappers. Each entry is mirrored as ps/<name>.ps1 and sh/<name>.sh. Per WRAPPER_DEDUP_PLAN.md, a future generator (TASK-ASR follow-up) will regenerate the 14 wrapper files from this manifest, and a parity validator will enforce drift detection.",
  "schemaVersion": "atm.rootDropWrappers.v0.1",
  "wrappers": [
    {
      "name": "atm-create",
      "subcommand": "create",
      "extraArgs": ["--bucket", "CORE", "--dry-run"],
      "alwaysJson": true
    },
    {
      "name": "atm-evidence",
      "subcommand": "explain",
      "extraArgs": ["--why", "blocked"],
      "alwaysJson": true
    },
    {
      "name": "atm-handoff",
      "subcommand": "handoff",
      "extraArgs": ["summarize"],
      "alwaysJson": true
    },
    {
      "name": "atm-lock",
      "subcommand": "lock",
      "extraArgs": ["check"],
      "alwaysJson": true
    },
    {
      "name": "atm-next",
      "subcommand": "next",
      "extraArgs": [],
      "alwaysJson": true
    },
    {
      "name": "atm-orient",
      "subcommand": "orient",
      "extraArgs": ["--cwd", "."],
      "alwaysJson": true
    },
    {
      "name": "atm-upgrade-scan",
      "subcommand": "upgrade",
      "extraArgs": ["--scan"],
      "alwaysJson": true
    }
  ],
  "parityContract": {
    "workingDirDerivation": "script_dir/../../..",
    "argumentForwarding": "verbatim",
    "exitCodePropagation": "preserved",
    "shells": ["ps", "sh"]
  }
}
