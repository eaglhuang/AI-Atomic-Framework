{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.invalid/schemas/experience-loop/memory-nudge.schema.json",
  "title": "ATM Memory Nudge",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "workItemId",
    "scope",
    "suggestedKey",
    "suggestedContent",
    "rationale",
    "evidenceRefs",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "atm.memoryNudge.v0.1" },
    "id": { "type": "string", "minLength": 1 },
    "workItemId": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["repo", "user", "session"] },
    "suggestedKey": { "type": "string", "minLength": 1 },
    "suggestedContent": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "generatedAt": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
