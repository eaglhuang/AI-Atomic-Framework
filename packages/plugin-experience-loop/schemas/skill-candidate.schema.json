{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-atomic-framework.invalid/schemas/experience-loop/skill-candidate.schema.json",
  "title": "ATM Skill Candidate",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "sourceTaskId",
    "proposedName",
    "proposedDescription",
    "proposedApplyTo",
    "proposedSteps",
    "confidence",
    "patternTags",
    "evidenceRefs",
    "lifecycleMode",
    "status",
    "generatedAt",
    "review"
  ],
  "properties": {
    "schemaVersion": { "const": "atm.skillCandidate.v0.1" },
    "id": { "type": "string", "minLength": 1 },
    "sourceTaskId": { "type": "string", "minLength": 1 },
    "proposedName": { "type": "string", "minLength": 1 },
    "proposedDescription": { "type": "string", "minLength": 1 },
    "proposedApplyTo": { "type": "array", "items": { "type": "string" } },
    "proposedSteps": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "patternTags": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "lifecycleMode": { "const": "birth" },
    "status": { "const": "candidate" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "review": {
      "type": "object",
      "required": ["required", "route"],
      "properties": {
        "required": { "type": "boolean" },
        "route": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
