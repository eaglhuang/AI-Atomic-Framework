{
  "name": "@ai-atomic-framework/agent-pack-gemini",
  "version": "0.0.0",
  "private": false,
  "description": "Gemini agent pack for ATM command files under .gemini/commands/.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/build-package-dist.ts --package packages/agent-pack-gemini",
    "test": "node --experimental-strip-types ../../scripts/validate-package-skeleton.ts --mode test",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-atomic-framework/agent-pack-sdk": "0.0.0",
    "@ai-atomic-framework/integration-gemini": "0.0.0",
    "@ai-atomic-framework/integrations-core": "0.0.0",
    "typescript": "^5.9.3"
  },
  "types": "./dist/index.d.ts"
}